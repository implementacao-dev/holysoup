<div class="kit-selection-faq-landing">
  <div class="kit-selection-faq-container">
    <div id="escolha-seu-kit" class="kit-selection-wrapper">
      <div class="kit-selection-content">
        {% if section.settings.kit_title != blank %}
          <h2 id="kit-selection-title" class="kit-selection-title">{{ section.settings.kit_title }}</h2>
        {% endif %}

        <div class="kit-options">
          {% assign action_type = section.settings.action_type | default: 'add_to_cart' %}
          {% assign kit_option_blocks = section.blocks | where: 'type', 'kit_option' %}

          {% for block in kit_option_blocks %}
            {% assign block_product = block.settings.product %}
            {% if block_product != blank %}
              {% assign block_variant = block_product.selected_or_first_available_variant %}
              <label class="kit-option" {{ block.shopify_attributes }}>
                <input
                  type="radio"
                  name="kit-option"
                  value="{{ forloop.index }}"
                  class="kit-option-radio"
                  {% if forloop.first %}
                    checked
                  {% endif %}
                  {% if action_type == 'add_to_cart' %}
                    data-variant-id="{{ block_variant.id }}"
                    data-quantity="1"
                    data-action="add_to_cart"
                  {% else %}
                    data-yampi-url="{{ block.settings.yampi_url }}"
                    data-action="redirect_yampi"
                  {% endif %}
                >
                <div class="kit-option-content">
                  {% if block.settings.discount_badge != blank or block.settings.free_shipping_text != blank %}
                    <div class="kit-badge-wrapper">
                      {% if block.settings.discount_badge != blank %}
                        <span class="kit-discount-badge kit-discount-badge-{{ forloop.index }}">
                          {{- block.settings.discount_badge -}}
                        </span>
                      {% endif %}
                      {% if block.settings.free_shipping_text != blank %}
                        <span class="kit-free-shipping">{{ block.settings.free_shipping_text }}</span>
                      {% endif %}
                    </div>
                  {% endif %}
                  <div class="kit-label-header">
                    <span class="kit-name">{{ block.settings.name }}</span>
                    <div class="kit-price-badge-wrapper">
                      <span class="kit-price">
                        <span class="kit-price-current">
                          {% if block.settings.current_price != blank %}
                            {% assign price_value = block.settings.current_price | times: 100 | round %}
                            {{ price_value | money }}
                          {% else %}
                            {{ block_variant.price | money }}
                          {% endif %}
                        </span>
                        {% if block.settings.original_price != blank %}
                          {% assign original_price_value = block.settings.original_price | times: 100 | round %}
                          <span class="kit-price-original">{{ original_price_value | money }}</span>
                        {% endif %}
                      </span>
                    </div>
                  </div>
                  {% if block.settings.quantity_price_text != blank or block.settings.quantity_yield_text != blank %}
                    <div class="kit-meal-info">
                      {% if block.settings.quantity_price_text != blank %}
                        <span class="kit-meal-price">{{ block.settings.quantity_price_text | replace: '.', ',' }}</span>
                      {% endif %}
                      {% if block.settings.quantity_yield_text != blank %}
                        <span class="kit-meal-yield"> | {{ block.settings.quantity_yield_text }}</span>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </label>
            {% endif %}
          {% endfor %}
        </div>

        {% if section.settings.benefits != blank %}
          <ul class="kit-benefits-list">
            {% assign benefits_list = section.settings.benefits | newline_to_br | split: '<br />' %}
            {% for benefit in benefits_list %}
              {% if benefit != blank %}
                <li class="kit-benefit-item">
                  {% render 'icon-check-2-landing',
                    class: 'kit-benefit-check',
                    width: '12',
                    fill: section.settings.check_icon_color,
                    stroke: section.settings.check_icon_color
                  %}
                  <span>{{ benefit | strip }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}

        {% assign kit_option_blocks = section.blocks | where: 'type', 'kit_option' %}
        {% if section.settings.button_text != blank and kit_option_blocks.size > 0 %}
          <button
            type="button"
            class="btn-primary kit-add-to-cart-btn"
            data-action-type="{{ action_type }}"
          >
            {{ section.settings.button_text }}
          </button>
        {% endif %}

        {% if section.settings.guarantee_text != blank %}
          <div class="kit-guarantee">
            {% render 'icon-check-landing', width: 16, height: 16, fill: section.settings.guarantee_text_color %}
            <span>{{ section.settings.guarantee_text }}</span>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="faq-wrapper">
      <div class="faq-content">
        {% if section.settings.faq_title != blank %}
          <h2 class="faq-title">{{ section.settings.faq_title }}</h2>
        {% endif %}

        <div class="faqs-list">
          {% for block in section.blocks %}
            {% if block.type == 'faq' %}
              <div class="faq-item" {{ block.shopify_attributes }}>
                <button type="button" class="faq-question" aria-expanded="false">
                  <span class="faq-question-text">{{ block.settings.question }}</span>
                  <span class="faq-icon"><span></span></span>
                </button>
                <div class="faq-answer">
                  <div class="faq-answer-content">
                    {{ block.settings.answer }}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% style %}
  #shopify-section-{{ section.id }} .kit-selection-faq-landing {
    padding: 70px 20px;
    background-color: {{ section.settings.bg_color }};
  }
  #shopify-section-{{ section.id }} .kit-selection-title,
  #shopify-section-{{ section.id }} .faq-title,
  #shopify-section-{{ section.id }} .kit-name,
  #shopify-section-{{ section.id }} .kit-price-current,
  #shopify-section-{{ section.id }} .kit-price-original,
  #shopify-section-{{ section.id }} .faq-question-text,
  #shopify-section-{{ section.id }} .faq-answer-content {
    color: {{ section.settings.title_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-discount-badge {
    background-color: {{ section.settings.tag_color }} !important;
    color: #ffffff !important;
  }
  #shopify-section-{{ section.id }} .kit-free-shipping,
  #shopify-section-{{ section.id }} .kit-meal-price {
    color: {{ section.settings.tag_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-selection-wrapper,
  #shopify-section-{{ section.id }} .kit-option-content {
    border-color: {{ section.settings.shadow_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-option-radio:checked + .kit-option-content {
    border-width: 2px !important;
  }
  #shopify-section-{{ section.id }} .kit-add-to-cart-btn {
    background-color: {{ section.settings.button_bg_color }} !important;
    color: {{ section.settings.button_text_color }} !important;
    border-color: {{ section.settings.button_shadow_color }} !important;
    box-shadow: 5px 5px 0 0 {{ section.settings.button_shadow_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-add-to-cart-btn:hover {
    background-color: {{ section.settings.button_hover_bg_color }} !important;
    color: {{ section.settings.button_hover_text_color }} !important;
    border-color: {{ section.settings.button_hover_shadow_color }} !important;
    box-shadow: 5px 5px 0 0 {{ section.settings.button_hover_shadow_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-discount-badge {
    background-color: {{ section.settings.discount_badge_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-option-radio:checked + .kit-option-content .kit-discount-badge {
    background-color: {{ section.settings.discount_badge_active_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-meal-price {
    color: {{ section.settings.meal_price_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-benefit-check path {
    fill: {{ section.settings.check_icon_color }} !important;
    stroke: {{ section.settings.check_icon_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-guarantee,
  #shopify-section-{{ section.id }} .kit-guarantee span,
  #shopify-section-{{ section.id }} .kit-guarantee svg path {
    background-color: transparent;
    color: {{ section.settings.guarantee_text_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-guarantee svg path {
    fill: {{ section.settings.guarantee_text_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-guarantee,
  #shopify-section-{{ section.id }} .kit-guarantee span {
    color: {{ section.settings.guarantee_text_color }} !important;
  }
  #shopify-section-{{ section.id }} .kit-guarantee {
    background-color: {{ section.settings.guarantee_bg_color }} !important;
  }
  #shopify-section-{{ section.id }} .faq-icon {
    border-color: {{ section.settings.title_color }} !important;
  }
  #shopify-section-{{ section.id }} .faq-icon::before,
  #shopify-section-{{ section.id }} .faq-icon::after {
    background-color: {{ section.settings.title_color }} !important;
  }
{% endstyle %}

{{ 'kit-selection-faq-landing.css' | asset_url | stylesheet_tag }}

