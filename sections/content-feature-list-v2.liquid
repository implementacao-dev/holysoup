      "default": "<p>Veja abaixo, o passo a passo de como utilizar os seus cupons no site da Kokeshi Cosméticos.</p>"
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "id": "card_color",
      "type": "color_background",
      "label": "Cor de fundo do card",
      "default": "#CD74A733"
    },
    {
      "id": "card_title_size",
      "type": "select",
      "label": "t:common.labels.title.size",
      "default": "text-h6 md:text-h5",
      "options": [
