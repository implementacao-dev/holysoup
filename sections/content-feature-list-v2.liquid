    {
      "id": "card_title_color",
      "type": "color",
      "label": "Cor do título do card",
      "default": "#CD74A7"
    },
    {
      "id": "card_title_bold_color",
      "type": "color",
      "label": "Cor do título do card em negrito",
      "default": "#339999"
    },
    {
      "id": "bg_icon_color",
      "type": "color",
      "label": "Cor do fundo do ícone",
      "default": "#ADDFE3"
    },
    {
      "id": "icon_color",
      "type": "color",
      "label": "Cor do ícone",
      "default": "#A94326"
    },
    {
      "type": "header",
      "content": "t:common.headers.background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:common.labels.background.color",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
