<section class="v3-vers" id="versatilidade">
  <div class="container">
    <div class="v3-vers-head">
      <div class="eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <h2>{{ section.settings.headline | escape }}</h2>
      <p class="lead">{{ section.settings.lead | escape }}</p>
    </div>
    <div class="v3-vers-grid">
      {%- for block in section.blocks -%}
        <div class="v3-vers-card" {{ block.shopify_attributes }}>
          <div class="emoji-box">{{ block.settings.emoji | escape }}</div>
          <h4>{{ block.settings.title | escape }}</h4>
          <p>{{ block.settings.description | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Holy · Versatilidade",
  "tag": "section",
  "class": "holy-section-versatilidade",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Cabeçalho" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "- Versatilidade -" },
    { "type": "text", "id": "headline", "label": "Título", "default": "Do café da manhã ao pós-treino." },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "Use o mel da Holy em qualquer momento do seu dia. Versátil de verdade - e fofo de quebra." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "☕" },
        { "type": "text", "id": "title", "label": "Título", "default": "No café ou chá" },
        { "type": "textarea", "id": "description", "label": "Descrição", "default": "Adoça com propósito - substitua o açúcar refinado por energia natural." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Holy · Versatilidade",
      "blocks": {
        "card-1": { "type": "card", "settings": { "emoji": "☕", "title": "No café ou chá", "description": "Adoça com propósito - substitua o açúcar refinado por energia natural." } },
        "card-2": { "type": "card", "settings": { "emoji": "🏋️", "title": "Pré e pós-treino", "description": "Carboidrato natural de absorção eficiente. Combustível pra performance." } },
        "card-3": { "type": "card", "settings": { "emoji": "🍳", "title": "Em receitas", "description": "Carameliza, equilibra e realça sabores em pratos doces e salgados." } },
        "card-4": { "type": "card", "settings": { "emoji": "🤒", "title": "Imunidade", "description": "Aliado de gerações pra garganta, gripes e bem-estar do dia a dia." } }
      }
    }
  ]
}
{% endschema %}
