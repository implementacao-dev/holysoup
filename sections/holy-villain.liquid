<section class="v2-villain" id="villain">
  <div class="container">
    <div class="v2-villain-head">
      <div class="eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <h2>{{ section.settings.headline | escape }}</h2>
      <p>{{ section.settings.description | escape }}</p>
    </div>

    <div class="v2-vs-grid">
      <div class="v2-vs-card bad">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div>
            <div class="label-top">{{ section.settings.bad_label | escape }}</div>
            <h3>{{ section.settings.bad_title | escape }}</h3>
          </div>
          <div style="position:relative;top:-10px;right:-10px">
            
<div class="v2-sticker" style="background:#9C3E1F;color:#F8EBC8;width:70px;height:70px;border:3px solid #2E1408;box-shadow:3px 3px 0 #2E1408;padding:10px;font-size:11px;--rot:15deg;font-family:Bowlby One,Lilita One,sans-serif;letter-spacing:0.04em">
  <div style="text-align:center;line-height:1.05"><div>{{ section.settings.bad_sticker | escape }}</div></div>
</div>
          </div>
        </div>
        <ul class="v2-vs-list">
          {%- for block in section.blocks -%}
            {% if block.type == 'bad_point' %}
              <li {{ block.shopify_attributes }}><span class="x">✕</span> {{ block.settings.text | escape }}</li>
            {% endif %}
          {%- endfor -%}
        </ul>
        <div style="margin-top:auto;padding-top:16px;border-top:2px dashed currentColor;font-family:var(--v2-font-hand);font-size:22px;color:var(--v2-rust-deep)">
          {{ section.settings.bad_quote | escape }}
        </div>
      </div>

      <div class="v2-vs-divider">
        <div class="vs-badge">VS</div>
      </div>

      <div class="v2-vs-card good">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div>
            <div class="label-top">{{ section.settings.good_label | escape }}</div>
            <h3>{{ section.settings.good_title | escape }}</h3>
          </div>
          <div style="position:relative;top:-10px;right:-10px">
            <div class="v2-vs-stamp-badge">
              {% render 'holy-villain-good-stamp', image: section.settings.good_stamp_image %}
            </div>
          </div>
        </div>
        <ul class="v2-vs-list">
          {%- for block in section.blocks -%}
            {% if block.type == 'good_point' %}
              <li {{ block.shopify_attributes }}><span class="check">✓</span> {{ block.settings.text | escape }}</li>
            {% endif %}
          {%- endfor -%}
        </ul>
        <div style="margin-top:auto;padding-top:16px;border-top:2px dashed currentColor;font-family:var(--v2-font-hand);font-size:22px;color:var(--v2-brown)">
          {{ section.settings.good_quote | escape }}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Holy · Vilão",
  "tag": "section",
  "class": "holy-section-villain",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Cabeçalho" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— O vilão —" },
    { "type": "text", "id": "headline", "label": "Título", "default": "Mel de supermercado vs Mel da Holy" },
    { "type": "textarea", "id": "description", "label": "Descrição", "default": "A indústria normalizou um líquido amarelo que finge ser mel. A gente não tá com pressa de seguir essa moda." },
    { "type": "header", "content": "Card negativo" },
    { "type": "text", "id": "bad_label", "label": "Label concorrência", "default": "Concorrência" },
    { "type": "text", "id": "bad_title", "label": "Título concorrência", "default": "O genérico" },
    { "type": "text", "id": "bad_sticker", "label": "Sticker", "default": "EVITE" },
    { "type": "text", "id": "bad_quote", "label": "Quote", "default": "isso ai não é mel, é refresco. — Holy" },
    { "type": "header", "content": "Card positivo" },
    { "type": "text", "id": "good_label", "label": "Label Holy", "default": "Mel da Holy" },
    { "type": "text", "id": "good_title", "label": "Título Holy", "default": "O original" },
    {
      "type": "image_picker",
      "id": "good_stamp_image",
      "label": "Selo do card Holy (opcional)",
      "info": "Selo circular no canto do card positivo. Arquivo quadrado PNG ou SVG. Recomendado: 200 × 200 px (exibido em 100 × 100 px). Se vazio, usa o selo padrão com urso."
    },
    { "type": "text", "id": "good_quote", "label": "Quote", "default": "essa daqui sou eu. — Holy" }
  ],
  "blocks": [
    { "type": "bad_point", "name": "Ponto negativo", "settings": [
      { "type": "text", "id": "text", "label": "Texto", "default": "Xarope de glucose adicionado" }
    ]},
    { "type": "good_point", "name": "Ponto positivo", "settings": [
      { "type": "text", "id": "text", "label": "Texto", "default": "Néctar puro da flor de laranjeira" }
    ]}
  ],
  "presets": [
    {
      "name": "Holy · Vilão",
      "blocks": {
        "bad-1": { "type": "bad_point", "settings": { "text": "Xarope de glucose adicionado" } },
        "bad-2": { "type": "bad_point", "settings": { "text": "Açúcar refinado pra \"padronizar\"" } },
        "bad-3": { "type": "bad_point", "settings": { "text": "Corante caramelo pra parecer mel" } },
        "bad-4": { "type": "bad_point", "settings": { "text": "Origem? Boa pergunta." } },
        "bad-5": { "type": "bad_point", "settings": { "text": "Embalagem genérica de plástico mole" } },
        "bad-6": { "type": "bad_point", "settings": { "text": "Nunca cristaliza (não é mel mesmo)" } },
        "good-1": { "type": "good_point", "settings": { "text": "Néctar puro da flor de laranjeira" } },
        "good-2": { "type": "good_point", "settings": { "text": "Zero açúcar, zero xarope, zero conservante" } },
        "good-3": { "type": "good_point", "settings": { "text": "4 certificações (BPF, FDA, IFS, SIF)" } },
        "good-4": { "type": "good_point", "settings": { "text": "Apiário rastreável (sim, a gente conhece a abelha)" } },
        "good-5": { "type": "good_point", "settings": { "text": "Embalagem-urso pra abraçar antes de abrir" } },
        "good-6": { "type": "good_point", "settings": { "text": "Cristaliza com o tempo — porque é puro mesmo" } }
      }
    }
  ]
}
{% endschema %}
