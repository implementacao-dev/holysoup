<section class="v3-metrics">
  <div class="v3-metrics-deco">
    {% render 'holy-metrics-deco', image: section.settings.deco_image %}
  </div>
  <div class="v3-metrics-grid">
    {%- for block in section.blocks -%}
      <div class="v3-metric" {{ block.shopify_attributes }}>
        <div class="num">{{ block.settings.number | escape }}</div>
        <div class="label">{{ block.settings.label | escape }}</div>
        <div class="desc">{{ block.settings.description | escape }}</div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Holy · Métricas",
  "tag": "section",
  "class": "holy-section-metrics",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "deco_image",
      "label": "Decoração de fundo (opcional)",
      "info": "Hexágono decorativo no canto superior direito. Arquivo quadrado PNG ou SVG. Recomendado: 320 × 320 px (exibido em 160 × 160 px com opacidade reduzida). Se vazio, usa o hexágono padrão."
    }
  ],
  "blocks": [
    {
      "type": "metric",
      "name": "Métrica",
      "settings": [
        { "type": "text", "id": "number", "label": "Número", "default": "+4.200" },
        { "type": "text", "id": "label", "label": "Rótulo", "default": "ursos entregues" },
        { "type": "textarea", "id": "description", "label": "Descrição", "default": "Em todo o Brasil, com carinho e mel de verdade." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Holy · Métricas",
      "blocks": {
        "metric-1": { "type": "metric", "settings": { "number": "+4.200", "label": "ursos entregues", "description": "Em todo o Brasil, com carinho e mel de verdade." } },
        "metric-2": { "type": "metric", "settings": { "number": "100%", "label": "puro e natural", "description": "Sem conservantes, sem adição de açúcar, sem mistérios." } },
        "metric-3": { "type": "metric", "settings": { "number": "4", "label": "certificações", "description": "BPF, FDA, IFS e SIF — qualidade comprovada." } }
      }
    }
  ]
}
{% endschema %}
