<div class="v2-ticker">
  <div class="v2-ticker-track">
    {%- for block in section.blocks -%}
      <span><span>{{ block.settings.text | escape }}</span><span class="dot">●</span></span>
    {%- endfor -%}
    {%- for block in section.blocks -%}
      <span><span>{{ block.settings.text | escape }}</span><span class="dot">●</span></span>
    {%- endfor -%}
    {%- for block in section.blocks -%}
      <span><span>{{ block.settings.text | escape }}</span><span class="dot">●</span></span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Holy · Ticker",
  "tag": "section",
  "class": "holy-section-ticker",
  "limit": 1,
  "blocks": [
    {
      "type": "item",
      "name": "Item do ticker",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto", "default": "🍯 100% PURO" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Holy · Ticker",
      "blocks": {
        "item-1": { "type": "item", "settings": { "text": "🍯 100% PURO" } },
        "item-2": { "type": "item", "settings": { "text": "✦ CERTIFICADO BPF · FDA · IFS · SIF" } },
        "item-3": { "type": "item", "settings": { "text": "🐻 EDIÇÃO SAFRA 2025" } },
        "item-4": { "type": "item", "settings": { "text": "🚚 FRETE GRÁTIS ACIMA DE R$89" } },
        "item-5": { "type": "item", "settings": { "text": "❤️ FEITO COM AMOR DE URSO" } },
        "item-6": { "type": "item", "settings": { "text": "🌼 NÉCTAR DA FLOR DE LARANJEIRA" } }
      }
    }
  ]
}
{% endschema %}
