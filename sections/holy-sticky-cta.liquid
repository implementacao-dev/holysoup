<div class="v2-sticky-cta" id="v2-sticky-cta">
  <div class="info">
    {% render 'holy-hybrid-bear', image: section.settings.bear_image, bear_symbol: section.settings.bear_symbol, width: 42, class: 'sticky-cta-bear' %}
    <div>
      <div class="label">{{ section.settings.label | escape }}</div>
      <div><span class="price">{{ section.settings.price | escape }}</span> <span style="font-size:13px;color:var(--v2-rose)">{{ section.settings.price_note | escape }}</span></div>
    </div>
  </div>
  <a class="v2-cta" href="{{ section.settings.url_kits | default: '/pages/kits' }}">{{ section.settings.cta_text | escape }}</a>
</div>

{% schema %}
{
  "name": "Holy · Sticky CTA",
  "tag": "section",
  "class": "holy-section-sticky-cta",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Textos" },
    {
      "type": "image_picker",
      "id": "bear_image",
      "label": "Urso do CTA (opcional)",
      "info": "Ícone ao lado do preço na barra fixa inferior. Arquivo quadrado PNG ou SVG com fundo transparente. Recomendado: 84 × 84 px (exibido em 42 × 44 px)."
    },
    {
      "type": "select",
      "id": "bear_symbol",
      "label": "Pose do urso (padrão)",
      "default": "bear-stand-happy",
      "options": [
        { "value": "bear-stand-happy", "label": "Stand" },
        { "value": "bear-wave-happy", "label": "Wave" },
        { "value": "bear-wave-wink", "label": "Wave wink" },
        { "value": "bear-stand-wink", "label": "Stand wink" },
        { "value": "bear-point-happy", "label": "Point" }
      ]
    },
    { "type": "text", "id": "label", "label": "Label", "default": "Duo Holy · MAIS AMADO" },
    { "type": "text", "id": "price", "label": "Preço", "default": "R$89,90" },
    { "type": "text", "id": "price_note", "label": "Observação do preço", "default": "frete grátis" },
    { "type": "text", "id": "cta_text", "label": "CTA", "default": "Quero →" },
    { "type": "header", "content": "Links dos kits" },
    { "type": "url", "id": "url_kits", "label": "URL principal (kits)" },
    { "type": "url", "id": "url_mini", "label": "URL Mini Holy" },
    { "type": "url", "id": "url_duo", "label": "URL Duo Holy" },
    { "type": "url", "id": "url_mamae", "label": "URL Mamãe Holy" }
  ],
  "presets": [{ "name": "Holy · Sticky CTA" }]
}
{% endschema %}
