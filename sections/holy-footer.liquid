<footer class="v2-footer">
  <div class="container">
    <div class="v2-footer-top">
      <div>
        <div class="v2-footer-brand">{{ section.settings.brand | escape }}</div>
        <p class="v2-footer-tagline">{{ section.settings.tagline | escape }}</p>
        <div style="display:flex;gap:10px">
          {%- for block in section.blocks -%}
            {% if block.type == 'social' %}
              <a href="{{ block.settings.url }}" target="_blank" rel="noopener" style="width:38px;height:38px;background:transparent;border:2px solid var(--v2-cream);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-family:var(--v2-font-stamp);font-size:11px" {{ block.shopify_attributes }}>{{ block.settings.label | escape }}</a>
            {% endif %}
          {%- endfor -%}
        </div>
      </div>
      <div>
        <h5>{{ section.settings.menu1_title | escape }}</h5>
        <ul>
          {%- for block in section.blocks -%}
            {% if block.type == 'menu1_link' %}
              <li {{ block.shopify_attributes }}><a href="{{ block.settings.url }}">{{ block.settings.label | escape }}</a></li>
            {% endif %}
          {%- endfor -%}
        </ul>
      </div>
      <div>
        <h5>{{ section.settings.menu2_title | escape }}</h5>
        <ul>
          {%- for block in section.blocks -%}
            {% if block.type == 'menu2_link' %}
              <li {{ block.shopify_attributes }}><a href="{{ block.settings.url }}">{{ block.settings.label | escape }}</a></li>
            {% endif %}
          {%- endfor -%}
        </ul>
      </div>
      <div>
        <h5>{{ section.settings.menu3_title | escape }}</h5>
        <ul>
          {%- for block in section.blocks -%}
            {% if block.type == 'menu3_link' %}
              <li {{ block.shopify_attributes }}><a href="{{ block.settings.url }}">{{ block.settings.label | escape }}</a></li>
            {% endif %}
          {%- endfor -%}
        </ul>
      </div>
    </div>
    <div class="v2-footer-bottom">
      <span>{{ section.settings.copyright | escape }}</span>
      <span>{{ section.settings.made_with | escape }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Holy · Footer",
  "tag": "section",
  "class": "holy-section-footer",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Marca" },
    { "type": "text", "id": "brand", "label": "Marca", "default": "Mel da Holy 🐻" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Mel silvestre 100% puro, com personalidade de urso. Da colmeia até sua casa em 7 dias, com carinho e zero açúcar adicionado." },
    { "type": "header", "content": "Menus" },
    { "type": "text", "id": "menu1_title", "label": "Título menu 1", "default": "Conhecer" },
    { "type": "text", "id": "menu2_title", "label": "Título menu 2", "default": "Comprar" },
    { "type": "text", "id": "menu3_title", "label": "Título menu 3", "default": "Ajuda" },
    { "type": "header", "content": "Rodapé" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2025 Mel da Holy · CNPJ XX.XXX.XXX/0001-XX · Edição Safra 2025" },
    { "type": "text", "id": "made_with", "label": "Assinatura", "default": "Feito com 🍯 e abraço de urso." },
    { "type": "header", "content": "Links dos kits" },
    { "type": "url", "id": "url_kits", "label": "URL principal (kits)" },
    { "type": "url", "id": "url_mini", "label": "URL Mini Holy" },
    { "type": "url", "id": "url_duo", "label": "URL Duo Holy" },
    { "type": "url", "id": "url_mamae", "label": "URL Mamãe Holy" }
  ],
  "blocks": [
    { "type": "social", "name": "Rede social", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "IG" },
      { "type": "url", "id": "url", "label": "URL" }
    ]},
    { "type": "menu1_link", "name": "Link Conhecer", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "O Mel" },
      { "type": "url", "id": "url", "label": "URL" }
    ]},
    { "type": "menu2_link", "name": "Link Comprar", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Mini Holy" },
      { "type": "url", "id": "url", "label": "URL" }
    ]},
    { "type": "menu3_link", "name": "Link Ajuda", "settings": [
      { "type": "text", "id": "label", "label": "Label", "default": "Central de Ajuda" },
      { "type": "url", "id": "url", "label": "URL" }
    ]}
  ],
  "presets": [
    {
      "name": "Holy · Footer",
      "blocks": {
        "social-1": { "type": "social", "settings": { "label": "IG", "url": "https://www.instagram.com/holyfoods" } },
        "social-2": { "type": "social", "settings": { "label": "TT", "url": "https://www.tiktok.com/@holyfoods" } },
        "social-3": { "type": "social", "settings": { "label": "YT", "url": "https://www.youtube.com/@holyfoods" } },
        "social-4": { "type": "social", "settings": { "label": "WA", "url": "https://wa.me/5500000000000" } },
        "menu1-1": { "type": "menu1_link", "settings": { "label": "O Mel", "url": "/pages/mel-da-holy#villain" } },
        "menu1-2": { "type": "menu1_link", "settings": { "label": "A jornada", "url": "/pages/mel-da-holy#jornada" } },
        "menu1-3": { "type": "menu1_link", "settings": { "label": "Transparência", "url": "/pages/mel-da-holy#trans" } },
        "menu1-4": { "type": "menu1_link", "settings": { "label": "Os ursos", "url": "/pages/mel-da-holy#cast" } },
        "menu2-1": { "type": "menu2_link", "settings": { "label": "Mini Holy", "url": "shopify://products/mini-holy" } },
        "menu2-2": { "type": "menu2_link", "settings": { "label": "Duo Holy", "url": "shopify://products/duo-holy" } },
        "menu2-3": { "type": "menu2_link", "settings": { "label": "Mamãe Holy", "url": "shopify://products/mamae-holy" } },
        "menu3-1": { "type": "menu3_link", "settings": { "label": "Central de Ajuda", "url": "/pages/contato" } },
        "menu3-2": { "type": "menu3_link", "settings": { "label": "Rastrear pedido", "url": "/account" } },
        "menu3-3": { "type": "menu3_link", "settings": { "label": "Trocas e devoluções", "url": "/policies/refund-policy" } },
        "menu3-4": { "type": "menu3_link", "settings": { "label": "Fale com o Holy", "url": "/pages/contato" } }
      }
    }
  ]
}
{% endschema %}
