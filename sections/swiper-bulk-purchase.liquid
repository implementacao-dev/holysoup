                    <path id="Caminho_6" data-name="Caminho 6" d="M53.124,24.176H19.86v-6.93a9.7,9.7,0,0,1,9.7-9.7h2.772a9.841,9.841,0,0,1,6.93,2.911,2.772,2.772,0,0,0,3.049.693h.139a2.633,2.633,0,0,0,.832-4.3A15.108,15.108,0,0,0,32.334,2H29.562A15.246,15.246,0,0,0,14.316,17.246v6.93H8.772A2.772,2.772,0,0,0,6,26.948V60.212a2.772,2.772,0,0,0,2.772,2.772H53.124A2.772,2.772,0,0,0,55.9,60.212V26.948A2.772,2.772,0,0,0,53.124,24.176ZM50.352,57.44H11.544V29.72H50.352Z" transform="translate(-6 -2)" fill="#f9f8ea"/>
                    <path id="Caminho_7" data-name="Caminho 7" d="M30.988,31.43a5.544,5.544,0,1,0-8.316,4.851v3.465a2.772,2.772,0,0,0,5.544,0V36.281A5.544,5.544,0,0,0,30.988,31.43Z" transform="translate(-0.635 7.239)" fill="#f9f8ea"/>
                  </g>
                </g>
              </g>
            </g>
          </svg>
        </div>
      </div>

      {%- for i in (1..4) -%}
        {%- capture col_id -%}collection_{{ i }}{%- endcapture -%}
        {%- assign collection = section.settings[col_id] -%}

        {%- if collection != blank -%}
          {%- assign available_products_count = 0 -%}
          {%- for product in collection.products limit: 12 -%}
            {%- if product.available -%}
              {%- assign available_products_count = available_products_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if available_products_count > 0 -%}
            <div class="bulk-collection-section" id="bulk-cat-{{ i }}">
              <div class="bulk-collection-title-container">
                <h3 class="bulk-collection-title">{{ collection.title | split: '-' | first | strip }}</h3>
              </div>
              <div class="bulk-product-grid">
                {%- for product in collection.products limit: 12 -%}
                  {%- if product.available -%}
                    {%- assign variant = product.selected_or_first_available_variant -%}
                    <div class="bulk-product-item" data-id="{{ variant.id }}" data-price="{{ variant.price }}">
                      <div class="bulk-product-image">
                        {%- if product.metafields.custom.popup_imagem_do_produto != blank -%}
                          {{
                            product.metafields.custom.popup_imagem_do_produto
                            | image_url: width: 300
                            | image_tag: loading: 'lazy'
                          }}
                        {%- else -%}
                          {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy' }}
                        {%- endif -%}
                      </div>
                      <div class="bulk-product-info">
                        <h4>
                          {%- if product.metafields.custom.popup_nome_do_produto != blank -%}
                            {{ product.metafields.custom.popup_nome_do_produto | metafield_tag }}
                          {%- else -%}
                            {{ product.title }}
                          {%- endif -%}
                        </h4>
                        <p class="bulk-product-price">{{ product.price | money }}</p>
                        <div class="bulk-qty-selector">
                          <button type="button" class="bulk-qty-btn minus">{% render 'icon-minus' %}</button>
                          <input type="text" class="bulk-qty-input" value="0" inputmode="numeric" pattern="[0-9]*">
                          <button type="button" class="bulk-qty-btn plus">{% render 'icon-plus' %}</button>
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="bulk-modal-footer">
      <div
        class="gift-progress-badges-modal"
        style="padding-bottom: 10px; margin-bottom: 0;"
      >
        {% assign relative_index = 0 %}
        {% for i in (1..4) %}
          {% capture gift_img_id %}tier_{{ i }}_gift_image{% endcapture %}
          {% capture gift_text_id %}tier_{{ i }}_gift_text{% endcapture %}
          {% assign gift_img = section.settings[gift_img_id] %}
          {% assign gift_text = section.settings[gift_text_id] %}

          {% if gift_img != blank or gift_text != blank %}
            {% assign relative_index = relative_index | plus: 1 %}
            <div
              class="bulk-gift-card-progress-modal"
              id="modal-gift-{{ i }}"
              data-relative-index="{{ relative_index }}"
            >
              <div class="bulk-gift-image-progress-modal">
                <div class="bulk-gift-lock-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 68 68">
                    <g id="cadeado" transform="translate(0.006 -0.096)">
                      <g id="invisible_box" data-name="invisible box" transform="translate(0 0)">
                        <rect id="Retângulo_15" data-name="Retângulo 15" width="68" height="68" transform="translate(-0.006 0.096)" fill="none"/>
                      </g>
                      <g id="icons_Q2" data-name="icons Q2" transform="translate(8.743 4.058)">
                        <g id="Grupo_7" data-name="Grupo 7">
                          <path id="Caminho_3" data-name="Caminho 3" d="M53.4,24.307H47.826V17.336A15.336,15.336,0,0,0,32.49,2H29.7A15.336,15.336,0,0,0,14.365,17.336v6.971H8.788A2.788,2.788,0,0,0,6,27.1V60.557a2.788,2.788,0,0,0,2.788,2.788H53.4a2.788,2.788,0,0,0,2.788-2.788V27.1A2.788,2.788,0,0,0,53.4,24.307ZM19.942,17.336A9.759,9.759,0,0,1,29.7,7.577H32.49a9.759,9.759,0,0,1,9.759,9.759v6.971H19.942ZM50.614,57.768H11.577V29.884H50.614Z" transform="translate(-6 -2)" fill="#fffef5"/>
                          <path id="Caminho_4" data-name="Caminho 4" d="M31.054,31.463a5.577,5.577,0,1,0-8.365,4.88v3.486a2.788,2.788,0,0,0,5.577,0V36.342A5.577,5.577,0,0,0,31.054,31.463Z" transform="translate(-0.521 7.436)" fill="#fffef5"/>
                        </g>
                      </g>
                    </g>
                  </svg>
                </div>
                {% if gift_img != blank %}
                  <img
                    src="{{ gift_img | image_url: width: 80 }}"
                    alt="{{ gift_text | escape }}"
                    width="48"
                    height="48"
                  >
                {% endif %}
              </div>
              <div class="bulk-gift-info-progress-modal">
                <div class="bulk-gift-progress-bar-modal">
                  <div class="bulk-gift-progress-fill-modal"><span></span></div>
                </div>
                <span class="bulk-gift-status-progress-modal"><span class="status-txt">Bloqueado</span></span>
                <span class="bulk-gift-name-progress-modal">
                  {{- gift_text | default: 'Brinde Especial' -}}
                </span>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="bulk-selected-list" id="bulk-selected-list">
      </div>
      <div class="bulk-summary">
        <div class="bulk-summary-info">
          <div class="bulk-summary-total">
            Total
            <div class="bulk-summary-prices">
              <span class="bulk-old-price">R$ 0,00</span>
              <span class="bulk-total-price">R$ 0,00</span>
            </div>
          </div>
        </div>
        <div class="bulk-summary-right">
          <div class="bulk-summary-items"><span class="bulk-total-qty">0</span> itens</div>
          <button type="button" class="bulk-view-list">
            ver todos
            <span class="bulk-arrow-icon"></span>
          </button>
        </div>
      </div>
      <a href="#" onclick="yampiClick()" class="button-checkout bulk-buy-btn" disabled>
        <span class="bulk-btn-text">COMPRAR AGORA</span>
        <div class="bulk-btn-loader">
          <svg
            aria-hidden="true"
            focusable="false"
            role="presentation"
            class="spinner"
            viewBox="0 0 66 66"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
          </svg>
        </div>
      </a>
      <div class="bulk-continue-shopping" id="bulk-continue-shopping">Continuar Comprando</div>
    </div>
  </div>
</section>

<script>
  (function() {
    window.money_format = {{ shop.money_format | json }};
    
    if (typeof Shopify === 'undefined') window.Shopify = {};
    if (!Shopify.formatMoney) {
      Shopify.formatMoney = function(cents, format) {
        if (typeof cents === 'string') cents = cents.replace('.', '');
        let value = '';
        const placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
        const formatString = format || window.money_format;

        function formatWithDelimiters(number, precision, thousands, decimal) {
          precision = precision || 2;
          thousands = thousands || ',';
          decimal = decimal || '.';
          if (isNaN(number) || number == null) return 0;
          number = (number / 100.0).toFixed(precision);
          const parts = number.split('.'),
            dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands),
            cents = parts[1] ? decimal + parts[1] : '';
          return dollars + cents;
        }

        switch (formatString.match(placeholderRegex)[1]) {
          case 'amount': value = formatWithDelimiters(cents, 2); break;
          case 'amount_no_decimals': value = formatWithDelimiters(cents, 0); break;
          case 'amount_with_comma_separator': value = formatWithDelimiters(cents, 2, '.', ','); break;
          case 'amount_no_decimals_with_comma_separator': value = formatWithDelimiters(cents, 0, '.', ','); break;
        }
        return formatString.replace(placeholderRegex, value);
      };
    }

    function init() {
      if (typeof Swiper === 'undefined') {
        setTimeout(init, 100);
        return;
      }

      const swiperBulk = new Swiper('.swiper-bulk', {
        slidesPerView: 1.1,
        spaceBetween: 10,
        freeMode: true,
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        breakpoints: {
          500: { slidesPerView: 2.2, spaceBetween: 15 },
          967: { slidesPerView: 3.2, spaceBetween: 20 },
          1200: { slidesPerView: 4, spaceBetween: 25 }
        }
      });

      const body = document.body;
      const overlay = document.querySelector('.bulk-modal-overlay');
      const container = document.querySelector('.bulk-modal-container');
      const closeBtn = document.querySelector('.bulk-modal-close');
      const slides = document.querySelectorAll('.swiper-bulk-purchase .swiper-slide');
      const modalBody = document.querySelector('.bulk-modal-body');

      const tiers = [
        { 
          qty: {{ section.settings.tier_1_qty | default: 3 }}, 
          discount: {{ section.settings.tier_1_pct | default: 10 }}, 
          name: 'BRONZE',
          color: '{{ section.settings.tier_1_color | default: "#C15C30" }}',
          barBgImage: '{{ section.settings.tier_1_bar_image | image_url: width: 1000 }}',
          badgeBgImage: '{{ section.settings.tier_1_badge_bg_image | image_url: width: 400 }}',
          gift: "{{ section.settings.tier_1_gift_text | escape }}",
          giftImg: "{{ section.settings.tier_1_gift_image | image_url: width: 200 }}"
        },
        { 
          qty: {{ section.settings.tier_2_qty | default: 6 }}, 
          discount: {{ section.settings.tier_2_pct | default: 15 }}, 
          name: 'PRATA',
          color: '{{ section.settings.tier_2_color | default: "#777371" }}',
          barBgImage: '{{ section.settings.tier_2_bar_image | image_url: width: 1000 }}',
          badgeBgImage: '{{ section.settings.tier_2_badge_bg_image | image_url: width: 400 }}',
          gift: "{{ section.settings.tier_2_gift_text | escape }}",
          giftImg: "{{ section.settings.tier_2_gift_image | image_url: width: 200 }}"
        },
        { 
          qty: {{ section.settings.tier_3_qty | default: 12 }}, 
          discount: {{ section.settings.tier_3_pct | default: 20 }}, 
          name: 'OURO',
          color: '{{ section.settings.tier_3_color | default: "#E3B760" }}',
          barBgImage: '{{ section.settings.tier_3_bar_image | image_url: width: 1000 }}',
          badgeBgImage: '{{ section.settings.tier_3_badge_bg_image | image_url: width: 400 }}',
          gift: "{{ section.settings.tier_3_gift_text | escape }}",
          giftImg: "{{ section.settings.tier_3_gift_image | image_url: width: 200 }}"
        },
        { 
          qty: {{ section.settings.tier_4_qty | default: 15 }}, 
          discount: {{ section.settings.tier_4_pct | default: 25 }}, 
          name: 'DIAMANTE',
          color: '{{ section.settings.tier_4_color | default: "#7BCA0C" }}',
          barBgImage: '{{ section.settings.tier_4_bar_image | image_url: width: 1000 }}',
          badgeBgImage: '{{ section.settings.tier_4_badge_bg_image | image_url: width: 1000 }}',
          gift: "{{ section.settings.tier_4_gift_text | escape }}",
          giftImg: "{{ section.settings.tier_4_gift_image | image_url: width: 200 }}"
        }
      ];

      const neutralColor = '{{ section.settings.tier_0_color | default: "#AFAA7A" }}';

      let productsCache = [];
      let cartSyncController = null;
      let lastSelectedHash = '';

      function updateProductsCache() {
        const items = document.querySelectorAll('.bulk-product-item');
        productsCache = Array.from(items).map(item => ({
          el: item,
          id: item.dataset.id,
          price: parseInt(item.dataset.price) || 0,
          input: item.querySelector('.bulk-qty-input'),
          priceEl: item.querySelector('.bulk-product-price'),
          img: item.querySelector('.bulk-product-image img'),
          minus: item.querySelector('.minus'),
          plus: item.querySelector('.plus')
        }));
      }

      async function syncWithCart() {
        try {
          const res = await fetch(window.Shopify.routes.root + 'cart.js');
          const cart = await res.json();
          if (productsCache.length === 0) updateProductsCache();
          productsCache.forEach(item => {
            const cartItem = cart.items.find(i => i.variant_id == item.id);
            const qty = cartItem ? cartItem.quantity : 0;
            if (item.input) item.input.value = qty;
            if (qty > 0) item.el.classList.add('qty-active'); else item.el.classList.remove('qty-active');
          });
          updateTotals();
        } catch (e) {
          console.error('Error syncing with cart:', e);
          updateTotals();
        }
      }

      async function openModal(index) {
        if (modalBody) {
          modalBody.style.scrollBehavior = 'auto';
          modalBody.scrollTop = 0;
        }
        overlay.classList.add('active');
        container.classList.add('active');
        body.style.overflow = 'hidden';
        window.isInitialSync = true;
        updateProductsCache();
        await syncWithCart();
        window.isInitialSync = false;
        if (index) {
          setTimeout(() => {
            const target = document.getElementById(`bulk-cat-${index}`);
            if (target && modalBody) {
              const scrollTopTarget = (index === '1') ? 0 : target.offsetTop;
              modalBody.scrollTo({ top: scrollTopTarget, behavior: 'smooth' });
            }
          }, 500);
        }
      }

      function closeModal() {
        if (cartSyncController) cartSyncController.abort();
        overlay.classList.remove('active');
        container.classList.remove('active');
        body.style.overflow = '';
      }

      slides.forEach(slide => {
        slide.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          openModal(slide.dataset.index);
        });
      });

      overlay.addEventListener('click', closeModal);
      closeBtn.addEventListener('click', closeModal);

      const totalPriceEl = document.querySelector('.bulk-total-price');
      const totalQtyEl = document.querySelector('.bulk-total-qty');
      const buyBtn = document.querySelector('.bulk-buy-btn');
      const selectedListEl = document.getElementById('bulk-selected-list');
      const oldPriceEl = document.querySelector('.bulk-old-price');
      const savingsEls = document.querySelectorAll('.bulk-savings-amount');
      const levelZeroMsg = document.querySelector('.level-zero-msg');
      const savingsActiveMsg = document.querySelector('.savings-active-msg');
      const levelMaxMsg = document.querySelector('.level-max-msg');
      const savingsContent = document.querySelector('.bulk-savings-content');
      const progressBar = document.querySelector('.bulk-progress-bar-container');
      const progressFill = document.querySelector('.bulk-progress-fill');
      const nextTierInfo = document.querySelector('.bulk-next-tier-info');
      const tierBadge = document.querySelector('.bulk-tier-badge-gem');
      const savingsHeader = document.querySelector('.bulk-savings-header');
      const nextLevelQtyText = document.querySelector('.next-level-qty-text');
      const nextLevelName = document.querySelector('.next-level-name');
      const nextLevelNum = document.querySelector('.next-level-num');
      const currentTierNameEl = document.querySelector('.current-tier-name');
      const currentTierPctEls = document.querySelectorAll('.current-tier-pct');

      function syncInputs(variantId, newQty) {
        productsCache.forEach(item => {
          if (item.id === variantId) {
            if (item.input) item.input.value = newQty;
            if (newQty > 0) item.el.classList.add('qty-active');
            else item.el.classList.remove('qty-active');
          }
        });
      }

      let cartUpdateTimer = null;
      function debouncedCartUpdate() {
        if (cartUpdateTimer) clearTimeout(cartUpdateTimer);
        cartUpdateTimer = setTimeout(async () => {
          if (cartSyncController) cartSyncController.abort();
          cartSyncController = new AbortController();
          const { signal } = cartSyncController;
          try {
            if (buyBtn) buyBtn.classList.add('loading');
            const cartRes = await fetch(window.Shopify.routes.root + 'cart.js', { signal });
            const cart = await cartRes.json();
            const updates = {};
            let changed = false;
            productsCache.forEach(item => {
              const qty = parseInt(item.input.value) || 0;
              const cartItem = cart.items.find(i => i.variant_id == item.id);
              const cartQty = cartItem ? cartItem.quantity : 0;
              if (qty !== cartQty) {
                updates[item.id] = qty;
                changed = true;
              }
            });
            if (changed) {
              await fetch(window.Shopify.routes.root + 'cart/update.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ updates }),
                signal
              });
              if (typeof window.updateCart === 'function') window.updateCart();
              window.dispatchEvent(new CustomEvent('cart-change', { bubbles: true }));
            }
          } catch (e) {
            if (e.name !== 'AbortError') console.error('Cart sync error:', e);
          } finally {
            if (buyBtn && !signal.aborted) buyBtn.classList.remove('loading');
          }
        }, 600);
      }

      function updateTotals() {
        try {
          if (productsCache.length === 0) updateProductsCache();
          let total = 0;
          let itemsCount = 0;
          const selectedMap = new Map();

          productsCache.forEach(item => {
            const qty = parseInt(item.input.value) || 0;
            if (qty > 0) {
              if (!selectedMap.has(item.id)) {
                selectedMap.set(item.id, { qty, imgSrc: item.img ? item.img.src : '', price: item.price });
                total += item.price * qty;
                if (item.price > 0) {
                  itemsCount += qty;
                }
              }
            }
          });

          const currentHash = Array.from(selectedMap.entries()).map(([id, d]) => `${id}:${d.qty}`).join('|');
          if (currentHash !== lastSelectedHash) {
            lastSelectedHash = currentHash;
            if (selectedListEl) {
              if (itemsCount === 0) {
                selectedListEl.innerHTML = '';
                selectedListEl.classList.remove('active');
              } else {
                let html = '';
                selectedMap.forEach((d, id) => {
                  html += `<div class="bulk-selected-item" data-variant-id="${id}"><img src="${d.imgSrc}" class="bulk-selected-img" loading="lazy"> <span class="bulk-selected-qty">${d.qty}</span> <div class="bulk-selected-remove"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></div></div>`;
                });
                selectedListEl.innerHTML = html;
              }
            }
          }

          let currentTier = null;
          tiers.forEach(t => { if (itemsCount >= t.qty) currentTier = t; });
          const tierIndex = currentTier ? tiers.indexOf(currentTier) : -1;
          const nextTier = (tierIndex < tiers.length - 1) ? tiers[tierIndex + 1] : null;
          const discountPct = currentTier ? currentTier.discount : 0;
          const discountedTotal = total * (1 - discountPct / 100);
          const savingsAmount = total * (discountPct / 100);

          if (totalPriceEl) totalPriceEl.textContent = Shopify.formatMoney(discountedTotal, window.money_format);
          if (totalQtyEl) totalQtyEl.textContent = itemsCount;
          if (buyBtn) {
            if (itemsCount === 0) {
              buyBtn.setAttribute('disabled', 'disabled');
            } else {
              buyBtn.removeAttribute('disabled');
            }
          }
          if (oldPriceEl) {
            oldPriceEl.textContent = itemsCount > 0 ? Shopify.formatMoney(total, window.money_format) : '';
            oldPriceEl.style.display = discountPct > 0 ? 'inline' : 'none';
          }
          savingsEls.forEach(el => el.textContent = Shopify.formatMoney(savingsAmount, window.money_format));

          if (itemsCount === 0) {
            if (levelZeroMsg) levelZeroMsg.style.display = 'block';
            if (savingsContent) savingsContent.style.display = 'none';
            if (levelMaxMsg) levelMaxMsg.style.display = 'none';
            if (savingsHeader) {
               savingsHeader.style.backgroundColor = '#F9F8EA';
               savingsHeader.style.backgroundImage = 'none';
               savingsHeader.style.justifyContent = 'center';
            }
          } else {
            if (levelZeroMsg) levelZeroMsg.style.display = 'none';
            if (savingsHeader) {
               savingsHeader.style.backgroundColor = '#F9F8EA';
               savingsHeader.style.backgroundImage = 'none';
               savingsHeader.style.justifyContent = 'space-between';
               const sTxt = savingsHeader.querySelector('.savings-prefix');
               const aTxt = savingsHeader.querySelector('.bulk-savings-amount');
               if (sTxt) sTxt.style.color = '#1a1a1a';
               if (aTxt) aTxt.style.color = '#1a1a1a';
            }
          }

          if (progressFill) {
            const maxQty = tiers[tiers.length - 1]?.qty || 24;
            progressFill.style.width = Math.min((itemsCount / maxQty) * 100, 100) + '%';
            if (currentTier && currentTier.barBgImage) {
               progressFill.style.backgroundImage = `url(${currentTier.barBgImage})`;
               progressFill.style.backgroundSize = 'cover';
            } else if (currentTier) {
               progressFill.style.backgroundColor = currentTier.color;
               progressFill.style.backgroundImage = 'none';
            } else {
               progressFill.style.backgroundColor = neutralColor;
               progressFill.style.backgroundImage = 'none';
            }
          }

          if (nextTier) {
            if (savingsContent && itemsCount > 0) savingsContent.style.display = 'flex';
            if (levelMaxMsg) levelMaxMsg.style.display = 'none';
            if (savingsActiveMsg) savingsActiveMsg.style.display = 'flex';
            if (tierBadge) tierBadge.style.display = 'flex';
            const needed = nextTier.qty - itemsCount;
            if (nextLevelQtyText) nextLevelQtyText.textContent = `${needed} ${needed === 1 ? 'item' : 'itens'}`;
            if (nextLevelName) nextLevelName.textContent = nextTier.name;
            if (nextLevelNum) nextLevelNum.textContent = tiers.indexOf(nextTier) + 1;
            if (nextTierInfo) {
              nextTierInfo.style.display = itemsCount > 0 ? 'block' : 'none';
              nextTierInfo.innerHTML = `${needed === 1 ? 'Falta' : 'Faltam'} <strong class="next-level-qty-text">${needed} ${needed === 1 ? 'item' : 'itens'}</strong> para desbloquear NÍVEL <span class="next-level-num">${tiers.indexOf(nextTier) + 1}</span> <strong class="next-level-name">${nextTier.name}</strong>`;
            }
            if (progressBar) progressBar.style.display = itemsCount > 0 ? 'block' : 'none';
          } else {
            if (savingsContent) savingsContent.style.display = 'none';
            if (levelMaxMsg) levelMaxMsg.style.display = 'block';
            if (savingsHeader) {
               savingsHeader.style.justifyContent = 'center';
               const lastT = tiers[tiers.length - 1];
               if (lastT) {
                 if (lastT.badgeBgImage) {
                   savingsHeader.style.backgroundImage = `url(${lastT.badgeBgImage})`;
                   savingsHeader.style.backgroundSize = 'cover';
                 } else {
                   savingsHeader.style.backgroundColor = lastT.color;
                   savingsHeader.style.backgroundImage = 'none';
                 }
                 const aEl = levelMaxMsg.querySelector('.bulk-savings-amount');
                 const pEl = levelMaxMsg.querySelector('.savings-prefix');
                 const isDark = (lastT.name === 'DIAMANTE' || lastT.name === 'SUPREMO' || lastT.color === '#7BCA0C');
                 if (aEl) aEl.style.color = isDark ? '#344F53' : '#fff';
                 if (pEl) pEl.style.color = isDark ? '#344F53' : '#fff';
               }
            }
          }

          if (currentTierNameEl) currentTierNameEl.textContent = currentTier ? currentTier.name : 'NENHUM';
          currentTierPctEls.forEach(el => {
            const isGem = el.classList.contains('bulk-tier-badge-gem');
            const targetTier = isGem ? (nextTier || currentTier || tiers[0]) : (currentTier || { discount: 0, color: neutralColor });
            if (isGem) {
              if (targetTier.badgeBgImage) {
                el.style.backgroundImage = `url(${targetTier.badgeBgImage})`;
                el.style.backgroundSize = tiers.indexOf(targetTier) === tiers.length - 1 ? 'initial' : '100% 100%';
              } else {
                el.style.backgroundColor = targetTier.color;
                el.style.backgroundImage = 'none';
              }
              el.style.color = (targetTier.name === 'DIAMANTE' || targetTier.name === 'SUPREMO') ? '#344F53' : '#fff';
              el.innerHTML = `<span style="display:flex; transform: rotate(-8deg);"><strong>${targetTier.discount}</strong>%</span>`;
            } else {
              el.textContent = `${discountPct}%`;
              if (currentTier) {
                if (currentTier.badgeBgImage) {
                  el.style.backgroundImage = `url(${currentTier.badgeBgImage})`;
                  el.style.backgroundSize = tiers.indexOf(currentTier) === tiers.length - 1 ? 'initial' : '100% 100%';
                } else {
                  el.style.backgroundColor = currentTier.color;
                  el.style.backgroundImage = 'none';
                }
                el.style.color = (currentTier.name === 'DIAMANTE' || currentTier.name === 'SUPREMO') ? '#344F53' : '#fff';
              } else {
                el.style.backgroundColor = neutralColor;
                el.style.backgroundImage = 'none';
                el.style.color = '#fff';
              }
            }
          });

          productsCache.forEach(item => {
            if (!item.priceEl) return;
            if (discountPct > 0) {
              const dPrice = item.price * (1 - discountPct / 100);
              item.priceEl.innerHTML = `<span style="text-decoration: line-through; opacity: 0.6; font-size: 0.85em; display: block;">${Shopify.formatMoney(item.price, window.money_format)}</span> <div>${Shopify.formatMoney(dPrice, window.money_format)}</div>`;
            } else {
              item.priceEl.innerHTML = `<div>${Shopify.formatMoney(item.price, window.money_format)}</div>`;
            }
          });

          let activeGiftTier = null;
          let activeGiftIndex = -1;
          tiers.forEach((t, i) => { if (itemsCount >= t.qty && t.gift) { activeGiftTier = t; activeGiftIndex = i; } });
          if (typeof window.lastSeenGiftIndex === 'undefined') window.lastSeenGiftIndex = -1;
          let isNewGift = false;
          if (activeGiftIndex > window.lastSeenGiftIndex) {
            if (!window.isInitialSync) { isNewGift = true; window.giftCardDismissed = false; }
            window.lastSeenGiftIndex = activeGiftIndex;
          } else if (activeGiftIndex < window.lastSeenGiftIndex) {
            window.lastSeenGiftIndex = activeGiftIndex;
          }

          const giftCard = document.getElementById('bulk-gift-card');
          if (giftCard && modalBody) {
            if (activeGiftTier && isNewGift && !window.giftCardDismissed) {
              giftCard.classList.add('show');
              document.getElementById('gift-title').textContent = activeGiftTier.gift;
              document.getElementById('gift-visual').src = activeGiftTier.giftImg;
              if (window.giftTimer) clearTimeout(window.giftTimer);
              window.giftTimer = setTimeout(() => { giftCard.classList.remove('show'); window.giftCardDismissed = true; }, 4000);
            } else if (!activeGiftTier) {
              giftCard.classList.remove('show');
            }
          }

          for (let i = 1; i <= 4; i++) {
            const modalGift = document.getElementById('modal-gift-' + i);
            if (modalGift) {
              const targetQty = tiers[i - 1]?.qty || 99;
              const isUnlocked = itemsCount >= targetQty;
              modalGift.classList.toggle('is-unlocked', isUnlocked);
              modalGift.classList.toggle('is-locked', !isUnlocked);
              
              const statusTxt = modalGift.querySelector('.status-txt');
              const progressFill = modalGift.querySelector('.bulk-gift-progress-fill-modal');
              const giftName = modalGift.querySelector('.bulk-gift-name-progress-modal');
              
              if (statusTxt) {
                if (isUnlocked) {
                  statusTxt.innerHTML = '<strong>Ganhou</strong>';
                } else {
                  const relativeIdx = modalGift.dataset.relativeIndex || i;
                  const giftNum = relativeIdx.toString().padStart(2, '0');
                  statusTxt.innerHTML = `Desbloquear <strong>Brinde ${giftNum}</strong>`;
                }
              }

              if (giftName) {
                giftName.style.display = isUnlocked ? 'block' : 'none';
              }
              
              if (progressFill) {
                const progressPct = isUnlocked ? 100 : Math.min((itemsCount / targetQty) * 100, 100);
                progressFill.style.width = progressPct + '%';
              }
            }
          }
        } catch (e) { console.error('Error in updateTotals:', e); }
      }

      if (selectedListEl) {
        selectedListEl.addEventListener('click', (e) => {
          const item = e.target.closest('.bulk-selected-item');
          if (!item) return;
          const vid = item.dataset.variantId;
          if (e.target.closest('.bulk-selected-remove')) {
            syncInputs(vid, 0); updateTotals(); debouncedCartUpdate();
          } else if (e.target.classList.contains('bulk-selected-img')) {
            const gridItem = productsCache.find(i => i.id === vid)?.el;
            if (gridItem && modalBody) {
              modalBody.scrollTo({ top: gridItem.offsetTop - 20, behavior: 'smooth' });
              gridItem.style.boxShadow = '0 0 0 2px #ff5017';
              setTimeout(() => gridItem.style.boxShadow = '', 1500);
            }
          }
        });
      }

      const giftClose = document.getElementById('bulk-gift-close');
      if (giftClose) giftClose.onclick = () => { window.giftCardDismissed = true; document.getElementById('bulk-gift-card').classList.remove('show'); };

      function attachListeners() {
        const modalContainer = document.querySelector('.bulk-modal-container');
        if (modalContainer && !modalContainer.dataset.touchListenersAttached) {
          modalContainer.dataset.touchListenersAttached = 'true';
          let touchStartY = 0;
          let touchTimer = null;
          
          modalContainer.addEventListener('touchstart', (e) => {
            const el = e.target.closest('.bulk-product-item');
            if (el) {
              touchStartY = e.touches[0].clientY;
              const vid = el.dataset.id;
              
              if (touchTimer) clearTimeout(touchTimer);
              touchTimer = setTimeout(() => {
                el.classList.add('is-hover');
                const product = productsCache.find(p => p.id === vid);
                if (product && (parseInt(product.input.value) || 0) === 0) {
                  syncInputs(vid, 1);
                  updateTotals();
                  debouncedCartUpdate();
                }
              }, 180);
            }
          }, {passive: true});

          modalContainer.addEventListener('touchmove', (e) => {
            const el = e.target.closest('.bulk-product-item');
            if (el) {
              const deltaY = Math.abs(e.touches[0].clientY - touchStartY);
              if (deltaY > 10) {
                el.classList.remove('is-hover');
                if (touchTimer) clearTimeout(touchTimer);
              }
            }
          }, {passive: true});
          
          modalContainer.addEventListener('touchend', (e) => {
            if (touchTimer) clearTimeout(touchTimer);
            const el = e.target.closest('.bulk-product-item');
            if (el) {
              setTimeout(() => el.classList.remove('is-hover'), 200);
            }
          }, {passive: true});

          modalContainer.addEventListener('touchcancel', (e) => {
            if (touchTimer) clearTimeout(touchTimer);
            const el = e.target.closest('.bulk-product-item');
            if (el) el.classList.remove('is-hover');
          }, {passive: true});
        }

        productsCache.forEach(item => {
          item.el.onclick = () => {
            const currentVal = parseInt(item.input.value) || 0;
            if (currentVal === 0) {
              syncInputs(item.id, 1);
              updateTotals();
              debouncedCartUpdate();
            }
          };

          if (item.minus) item.minus.onclick = (e) => {
            e.stopPropagation();
            const val = Math.max((parseInt(item.input.value) || 0) - 1, 0);
            syncInputs(item.id, val); updateTotals(); debouncedCartUpdate();
          };
          if (item.plus) item.plus.onclick = (e) => {
            e.stopPropagation();
            const val = (parseInt(item.input.value) || 0) + 1;
            syncInputs(item.id, val); updateTotals(); debouncedCartUpdate();
          };
          if (item.input) {
            item.input.onclick = (e) => e.stopPropagation();
            item.input.oninput = (e) => {
              let v = e.target.value.replace(/\D/g, '');
              if (v !== '') v = Math.min(parseInt(v), 99);
              e.target.value = v;
              syncInputs(item.id, v === '' ? 0 : parseInt(v));
              updateTotals(); debouncedCartUpdate();
            };
            item.input.onblur = (e) => { if (e.target.value === '') e.target.value = 0; updateTotals(); };
            item.input.onkeydown = (e) => { if (e.key === 'Enter') item.input.blur(); };
          }
        });
      }

      const continueShoppingBtn = document.getElementById('bulk-continue-shopping');
      if (continueShoppingBtn) {
        continueShoppingBtn.onclick = () => closeModal();
      }

      if (document.querySelector('.bulk-view-list')) {
        document.querySelector('.bulk-view-list').onclick = () => {
          if ((parseInt(totalQtyEl.textContent) || 0) > 0) selectedListEl.classList.toggle('active');
        };
      }

      function isIosSafari() {
        var ua = (window.navigator && navigator.userAgent) || '';
        var iOS = !!ua.match(/iPad/i) || !!ua.match(/iPhone/i);
        var webkit = !!ua.match(/WebKit/i);
        var iOSSafari = iOS && webkit && !ua.match(/CriOS/i);
        return iOSSafari;
      }

      function applyIosSafariFix() {
        if (!isIosSafari()) return;

        function shouldPrevent(target) {
          var tagName = target.tagName ? target.tagName.toLowerCase() : '';
          var isProductItem = target.closest && target.closest('.bulk-product-item') !== null;
          return tagName === 'a' || tagName === 'button' || isProductItem;
        }

        var eventSelector = {
          touchend: function (_, target) {
            target.dataset._clicked_ = '';
            target.dataset._mousemove_ = '0';
            target.dataset._timeOutId_ = '';
          },
          mouseover: function (e) {
            e.preventDefault();
          },
          mousemove: function (e, target) {
            e.preventDefault();
            var _mousemoves = +(target.dataset._mousemove_ || '0');
            _mousemoves = _mousemoves + 1;
            target.dataset._mousemove_ = _mousemoves;
            if (_mousemoves > 1 && !target.dataset._timeOutId_) {
              var id = setTimeout(function () {
                target.click();
              }, 80);
              target.dataset._timeOutId_ = id;
            }
          },
          click: function (e, target) {
            if (target.dataset._clicked_) {
              if (e.isTrusted) {
                e.preventDefault();
              }
              return;
            }
            if (target.dataset._timeOutId_) {
              clearTimeout(+target.dataset._timeOutId_);
            }
            target.dataset._clicked_ = 'true';
          }
        };

        function preventHover(e) {
          var target = e.target.closest ? e.target.closest('a, button, .bulk-product-item') : e.target;
          if (!target || !(target.tagName && target.dataset)) return;
          if (!shouldPrevent(target)) return;
          var type = e.type;
          eventSelector[type] && eventSelector[type](e, target);
        }

        const modalContainer = document.querySelector('.bulk-modal-container');
        if (modalContainer) {
          modalContainer.addEventListener('touchend', preventHover, true);
          modalContainer.addEventListener('mouseover', preventHover, true);
          modalContainer.addEventListener('mousemove', preventHover, true);
          modalContainer.addEventListener('click', preventHover, true);
        }
      }

      function setupBuyBtnClickHandler() {
        if (!buyBtn) return;
        
        const newBtn = buyBtn.cloneNode(true);
        buyBtn.parentNode.replaceChild(newBtn, buyBtn);
        const currentBuyBtn = document.querySelector('.bulk-buy-btn');

        currentBuyBtn.addEventListener('click', function (e) {
          if (currentBuyBtn.hasAttribute('disabled')) {
             e.preventDefault();
             return;
          }

          e.preventDefault(); 
          currentBuyBtn.classList.add('loading');

          setTimeout(() => {
            window.location.href = buyBtn.href;
          }, 2000);
        });
      }

      updateProductsCache();
      attachListeners();
      updateTotals();

      if (window.location.search.includes('cart-popup')) {
        openModal();
      }
    }

    if (document.readyState === 'complete') {
      init();
    } else {
      window.addEventListener('load', init);
    }
  })();
</script>

