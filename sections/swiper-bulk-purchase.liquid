<script>
  (function() {
    const styleEl = document.getElementById('bulk-purchase-preload-images');
    let preloadCSS = '';
    const imagesToPreload = {{ section.settings.tier_1_bar_image | image_url: width: 1000 | json }} ? [
      {%- if section.settings.tier_1_bar_image != blank -%}'{{ section.settings.tier_1_bar_image | image_url: width: 1000 }}',{%- endif -%}
      {%- if section.settings.tier_1_badge_bg_image != blank -%}'{{ section.settings.tier_1_badge_bg_image | image_url: width: 400 }}',{%- endif -%}
      {%- if section.settings.tier_2_bar_image != blank -%}'{{ section.settings.tier_2_bar_image | image_url: width: 1000 }}',{%- endif -%}
      {%- if section.settings.tier_2_badge_bg_image != blank -%}'{{ section.settings.tier_2_badge_bg_image | image_url: width: 400 }}',{%- endif -%}
      {%- if section.settings.tier_3_bar_image != blank -%}'{{ section.settings.tier_3_bar_image | image_url: width: 1000 }}',{%- endif -%}
      {%- if section.settings.tier_3_badge_bg_image != blank -%}'{{ section.settings.tier_3_badge_bg_image | image_url: width: 400 }}',{%- endif -%}
      {%- if section.settings.tier_4_bar_image != blank -%}'{{ section.settings.tier_4_bar_image | image_url: width: 1000 }}',{%- endif -%}
      {%- if section.settings.tier_4_badge_bg_image != blank -%}'{{ section.settings.tier_4_badge_bg_image | image_url: width: 1000 }}'{%- endif -%}
    ] : [];
    
    imagesToPreload.forEach((url, index) => {
      if(url) {
        preloadCSS += `.preload-bg-images::after { content: url(${url}); display: none; }`;
      }
    });
    styleEl.innerHTML = preloadCSS;
  })();
</script>
