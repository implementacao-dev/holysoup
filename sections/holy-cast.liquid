        { "type": "text", "id": "tagline", "label": "Tagline", "default": "pra começar a história" },
        { "type": "text", "id": "price_now", "label": "Preço atual", "default": "R$49,90" },
        { "type": "text", "id": "price_was", "label": "Preço anterior", "default": "R$59,90" },
