<section class="v2-cast" id="cast">
  <div class="container">
    <div class="v2-cast-head">
      <div class="eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <h2>{{ section.settings.headline | escape }}</h2>
      <p>{{ section.settings.description | escape }}</p>
    </div>
    <div class="v2-cast-grid">
      {%- for block in section.blocks -%}
        <div class="v2-cast-card{% if block.settings.featured %} featured{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.ribbon != blank %}<div class="ribbon">{{ block.settings.ribbon | escape }}</div>{% endif %}
          <div class="character-stage" style="background:{{ block.settings.stage_color }}">
            <div class="stage-stamp">
              <div class="v2-sticker" style="background:{{ block.settings.sticker_bg }};color:{{ block.settings.sticker_color }};width:72px;height:72px;border:3px solid #2E1408;box-shadow:3px 3px 0 #2E1408;padding:10px;font-size:11px;--rot:{{ block.settings.sticker_rotation }}deg;font-family:Bowlby One,Lilita One,sans-serif;letter-spacing:0.04em">
                <div style="text-align:center;line-height:1.05">{{ block.settings.sticker_text | newline_to_br }}</div>
              </div>
            </div>
            <div class="cast-character">
              {% render 'holy-cast-character', image: block.settings.character_image, bear_symbol: block.settings.bear_symbol %}
            </div>
          </div>
          <div class="char-meta">{{ block.settings.meta | escape }}</div>
          <h3>{{ block.settings.title | escape }}</h3>
          <div class="tagline">{{ block.settings.tagline | escape }}</div>
          <div class="price-row">
            <span class="price-now">{{ block.settings.price_now | escape }}</span>
            <span class="price-was">{{ block.settings.price_was | escape }}</span>
          </div>
          <div class="price-meta">{{ block.settings.price_meta | escape }}</div>
          {{ block.settings.bullets }}
          <a class="v2-btn {{ block.settings.button_class }}" href="{{ block.settings.url }}">{{ block.settings.button_text | escape }}</a>
        </div>
      {%- endfor -%}
    </div>
    <div style="text-align:center;margin-top:48px;color:var(--v2-rose);font-size:15px">
      <span style="font-family:var(--v2-font-hand);font-size:22px;color:var(--v2-honey)">↑</span> {{ section.settings.footer_note | escape }}
    </div>
  </div>
</section>

{% schema %}
{
