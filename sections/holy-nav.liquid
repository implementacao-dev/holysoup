<nav class="v2-nav">
  <div class="v2-nav-links v3-nav-links">
    <a href="#villain">{{ section.settings.nav_mel | escape }}</a>
    <a href="#jornada">{{ section.settings.nav_jornada | escape }}</a>
    <a href="#versatilidade">{{ section.settings.nav_usar | escape }}</a>
    <a href="#reviews">{{ section.settings.nav_reviews | escape }}</a>
    <a href="#cast">{{ section.settings.nav_comprar | escape }}</a>
  </div>
  <div class="v2-nav-brand">
    {% render 'holy-hybrid-bear', image: section.settings.brand_image, bear_symbol: section.settings.brand_bear, width: 40, class: 'nav-brand-bear' %}
    <span>{{ section.settings.brand_text | escape }}</span>
  </div>
  <div class="v2-nav-right">
    <button type="button" class="v2-cart-btn" aria-label="{{ section.settings.cart_label | escape }}" @click.prevent="$dispatch('show-cart', true)">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
        <path d="M6 6h15l-2 10H8L6 6z" /><circle cx="9" cy="20" r="1.5" /><circle cx="18" cy="20" r="1.5" /><path d="M6 6L5 3H2" />
      </svg>
    </button>
    <a class="v2-cta" href="{{ section.settings.url_kits | default: '/pages/kits' }}"><span class="v2-cta-full">{{ section.settings.cta_full | escape }} </span><span class="v2-cta-short">{{ section.settings.cta_short | escape }} </span>→</a>
  </div>
</nav>

{% schema %}
{
  "name": "Holy · Nav",
  "tag": "section",
  "class": "holy-section-nav",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Navegação" },
    { "type": "text", "id": "brand_text", "label": "Marca", "default": "Mel da Holy" },
    {
      "type": "image_picker",
      "id": "brand_image",
      "label": "Logo urso (opcional)",
      "info": "Substitui o urso padrão ao lado do nome da marca. Arquivo quadrado PNG ou SVG com fundo transparente. Recomendado: 80 × 80 px (exibido em 40 × 40 px)."
    },
    {
      "type": "select",
      "id": "brand_bear",
      "label": "Pose do urso (padrão)",
      "default": "bear-stand-happy",
      "options": [
        { "value": "bear-stand-happy", "label": "Stand" },
        { "value": "bear-wave-happy", "label": "Wave" },
        { "value": "bear-wave-wink", "label": "Wave wink" },
        { "value": "bear-stand-wink", "label": "Stand wink" },
        { "value": "bear-point-happy", "label": "Point" }
      ]
    },
    { "type": "text", "id": "nav_mel", "label": "Link O Mel", "default": "O Mel" },
    { "type": "text", "id": "nav_jornada", "label": "Link Jornada", "default": "Jornada" },
    { "type": "text", "id": "nav_usar", "label": "Link Como usar", "default": "Como usar" },
    { "type": "text", "id": "nav_reviews", "label": "Link Reviews", "default": "Reviews" },
    { "type": "text", "id": "nav_comprar", "label": "Link Comprar", "default": "Comprar" },
    { "type": "text", "id": "cta_full", "label": "CTA completo", "default": "Quero o meu Urso" },
    { "type": "text", "id": "cta_short", "label": "CTA curto (mobile)", "default": "Quero" },
    { "type": "text", "id": "cart_label", "label": "Label do carrinho", "default": "Carrinho" },
    { "type": "header", "content": "Links dos kits" },
    { "type": "url", "id": "url_kits", "label": "URL principal (kits)" },
    { "type": "url", "id": "url_mini", "label": "URL Mini Holy" },
    { "type": "url", "id": "url_duo", "label": "URL Duo Holy" },
    { "type": "url", "id": "url_mamae", "label": "URL Mamãe Holy" }
  ],
  "presets": [{ "name": "Holy · Nav" }]
}
{% endschema %}
