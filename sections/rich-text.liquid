<link rel="stylesheet" href="{{ 'component-rte.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-rich-text.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rich-text.css' | asset_url | stylesheet_tag }}</noscript>
{% if settings.banner_animation == 'effect_1' %}<animated-component>{% endif %}
<div class="rich-text section-block-{{section.id}}">
  <div class="{% if section.settings.container == 'fullwidth' %}container-full{% elsif section.settings.container == '1770' %}container-1770{% elsif section.settings.container == '1170' %}container-1170{% else %}container{% endif %}">
    <div class="rich-text__blocks{% if section.settings.enable_column %} enable_column{% endif %} text-center" data-animate="{{ settings.banner_animation }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
        {%- when 'heading' -%}
            <h2 class="heading" style="--color-heading-style: {{ block.settings.heading_color }};--fontsize-heading-style: {{ block.settings.heading_size | append: 'px' }};--heading-size-mb-style: {{ block.settings.heading_size_mb | append: 'px' }};--heading-line-height-style: {{ block.settings.heading_line_height }}">{{ block.settings.heading | escape }}</h2>
        {%- when 'sub_heading' -%}
              <div class="rich-text__sub" style="--sub-heading-size-style: {{ block.settings.sub_heading_size | append: 'px' }};--sub-heading-color-style: {{ block.settings.sub_heading_color }};--font-weight-sub-heading-style: {{ block.settings.font_weight_sub_heading }};--margin-top-sub-heading-style: {{ block.settings.margin_top_sub_heading | append: 'px' }}"><p>{{ block.settings.sub_heading }}</p></div> 
        {%- when 'text' -%}
            <div class="rich-text__text rte" style="--color-text-style: {{ block.settings.text_color }};--fontsize-text-style: {{ block.settings.text_size | append: 'px' }};--width-text-style: {{ block.settings.text_width }};--margin-top-text-style: {{ block.settings.margin_top_text | append: 'px' }};--text-line-height-style: {{ block.settings.text_line_height }}">{{ block.settings.text }}</div>
        {%- when 'content' -%}
            <div class="rich-text__content rte" style="--color-content-style: {{ block.settings.content_color }};--fontsize-content-style: {{ block.settings.content_size | append: 'px' }};--width-content-style: {{ block.settings.content_width }};--margin-top-content-style: {{ block.settings.margin_top_content | append: 'px' }};--alignment-content-style: {{ block.settings.alignment_content }};">
                {%- if block.settings.content_top != blank -%}
                    <div class="rich-text__top">{{ block.settings.content_top }}</div>
                {%- endif -%}
                {%- if block.settings.content_bottom != blank and block.settings.button_text_more != blank -%}
                    <div class="rich-text__bottom">{{ block.settings.content_bottom }}</div>
                    <div class="btn--lessMore d-inline-block w-100" style="--margin_top_button-text-style: {{ block.settings.margin_top_button_text | append: 'px' }};">
                        <button type="button" class="button d-inline-block w-100" id="rich-text__lessMore" data-more="{{ block.settings.button_text_more }}" data-less="{{ block.settings.button_text_less }}" style=" --fontsize-button-text-style: {{ block.settings.button_text_font_size | append: 'px' }};--fontweight-button-text-style:{{ block.settings.button_text_font_weight }};--color-button-text-style: {{ block.settings.button_text_color }};--bg-button-text-style: {% if block.settings.button_text_bg_color_gradient != blank %}{{ block.settings.button_text_bg_color_gradient }}{% else %}{{ block.settings.button_text_bg_color }}{% endif %};--border-button-text-style: {{ block.settings.button_text_border_color }};--color-button-text-hover-style: {{ block.settings.button_text_color_hover }};--bg-button-text-hover-style: {% if block.settings.button_text_bg_color_hover_gradient != blank %}{{ block.settings.button_text_bg_color_hover_gradient }}{% else %}{{ block.settings.button_text_bg_color_hover }}{% endif %};--border-button-text-hover-style: {{ block.settings.button_text_border_color_hover }};--width-button-text-style: {{ block.settings.button_text_more_width | append: 'px' }};--padding_top_button-text-style: {{ block.settings.pd_top_button_text | append: 'px' }};--padding_bottom_button-text-style: {{ block.settings.pd_bottom_button_text | append: 'px' }}">{{ block.settings.button_text_more | escape }}</button>
                    </div>
                {%- endif -%}
            </div>
        {%- when 'button' -%}
            <a{% if block.settings.button_link == blank %} aria-disabled="true"{% else %} href="{{ block.settings.button_link }}"{% endif %} class="button" style="--color-button-style: {{ block.settings.button_color }};--bg-button-style: {% if block.settings.button_bg_gradient != blank %}{{ block.settings.button_bg_gradient }}{% else %}{{ block.settings.button_bg_color }}{% endif %};--border-button-style: {{ block.settings.button_border_color }};--color-button-hover-style: {{ block.settings.button_color_hover }};--bg-button-hover-style: {% if block.settings.button_bg_gradient_hover != blank %}{{ block.settings.button_bg_gradient_hover }}{% else %}{{ block.settings.button_bg_color_hover }}{% endif %};--border-button-hover-style: {{ block.settings.button_border_color_hover }};--width-button-style: {{ block.settings.button_width }};--margin_top_button-style: {{ block.settings.margin_top_button | append: 'px' }};{% if block.settings.enable_underline_button %}text-decoration: underline;text-underline-offset: 0.2rem;text-decoration-color: #051c424d{% endif %}">{{ block.settings.button_label | escape }}</a>
        {%- when 'social_media' -%}
            {%- liquid
                assign social_spacing_top = block.settings.social_spacing_top | append: 'px'
                assign social_spacing_bottom = block.settings.social_spacing_bottom | append: 'px'
                assign social_icon_color = block.settings.social_icon_color
                assign social_icon_background_color = block.settings.social_icon_background_color
                assign social_icon_background_gradient = block.settings.social_icon_background_gradient
                assign social_icon_hover_color = block.settings.social_icon_hover_color
                assign social_icon_background_hover_color = block.settings.social_icon_background_hover_color
                assign social_icon_background_hover_gradient = block.settings.social_icon_background_hover_gradient
                assign social_icon_ring_color = block.settings.social_icon_ring_color
            -%}
            <div class="item clearfix social-media-container" style="--social-margin-top: {{ social_spacing_top }};--social-margin-bottom: {{ social_spacing_bottom }};--social-icon-color: {% if social_icon_color != blank %}{{ social_icon_color }}{% endif %};--social-icon-background-color: {% if social_icon_background_gradient != blank %}{{ social_icon_background_gradient }}{% elsif social_icon_background_color != blank %}{{ social_icon_background_color }}{% endif %};--social-icon-hover-color: {% if social_icon_hover_color != blank %}{{ social_icon_hover_color }}{% endif %};--soical-icon-background-hover-color: {% if  social_icon_background_hover_gradient != blank %}{{ social_icon_background_hover_gradient }}{% elsif social_icon_background_hover_color != blank %}{{ social_icon_background_hover_color }}{% endif %};--social-icon-ring-color: {% if social_icon_ring_color != blank %}{{ social_icon_ring_color }}{% endif %}">
                {% render 'halo-social-media-icons' %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
  {% if section.settings.wave !=blank %}
<div class="divider bottom rich-wave">
  
