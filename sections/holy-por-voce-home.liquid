<style>
  .slider-porvc-hs .swiper-slide{
    width: 65%;
    height: auto;
  }
  
  .slider-porvc-hs {
    padding: 40px 20px 60px 20px;
  }

  .porvc-hs {
    display: flex;
    align-items: center;
    flex-direction: column;
  }

  .description-porvc {
    width: 100%;
  }
  
  .porvc-hs .descubra-mais svg {
    width: 16px;
    height: auto;
    stroke-width: 2px;
  }

  .icon-porvc {
    background: var(--porvc-color);
    width: 45px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9px;
  }

  .icon-porvc svg {
    color: #fff;
    width: 20px;
    height: auto;
  }
  
  .porvc-hs-header {
    display: flex;
    gap: 15px;
    align-items: center;
    height: 100%;
    width: 100%;
  }

  .title-porvc b, highlight {
    color: {{ section.settings.highlight_color }};
    font-weight: 500;
  }
  
  .slider-porvc-hs .title-porvc {
    width: 60%;
    line-height: 1.2;
    font-weight: 600;
    font-size: 14px;
  }

  .porvc-hs {
    padding: 20px;
    background: {{ section.settings.card_background_color }};
    border-radius: 25px;
    height: calc(100% - 65px);
  }

  .swiper-slide-active .porvc-hs {
    box-shadow: 0px 0px 20px 0px rgba(0,0,0,0.01);
  }

  .porvc-hs .descubra-mais {
    font-size: 9px;
    font-weight: 100;
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 5px 0;
  }

  .slider-porvc-hs:not(.open-description) .description-porvc {
    height: 0px;
    opacity: 0;
    display: none;
  }

  @media (min-width: 1200px){
    .slider-porvc-hs .swiper-slide {
      width: 25%;
    }
  
    .slider-porvc-hs {
      padding: 40px 120px 60px 120px;
    }
  }
</style>
{% if section.settings.borda-superior %}
  {% render 'borda-superior', cor: section.settings.color-borda-superior %}
{% endif %}
<div class="swiper slider-porvc-hs max-container" style="background-color: {{ section.settings.background_color }};">
  <div class="header-widget custom-font light-font">
    <h3 style="text-align: center; color: {{ section.settings.title_color }};">{% if section.settings.section_title != blank %}{{ section.settings.section_title }}{% else %}O que a Holysoup<br />faz por você:{% endif %}</h3>
  </div>
  <div class="swiper-wrapper">
  {% for block in section.blocks %}
    {% assign content = block.settings.title | split: ": " %}
    <div class="swiper-slide">
      <div class="porvc-hs">
        <div class="porvc-hs-header">
          <div class="icon-porvc">
            {% if block.settings.icone %}
              <img src="{{ block.settings.icone | image_url }}">
            {% endif %}
          </div>
          <div class="title-porvc  custom-font">
            <span>
              {% if content.size > 1 %}
              <highlight>{{ content | first }}:</highlight><br /> {{ content | last }}
              {% else %}
              {{ block.settings.title }}
              {% endif %}
            </span>
            {% if block.settings.description != blank %}<a href="#" data-open-persona=".slider-porvc-hs" data-index="{{ forloop.index0 }}" class="descubra-mais">Descubra mais <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 50" width="512px" height="512px"><path d="M 25 2 C 12.309295 2 2 12.309295 2 25 C 2 37.690705 12.309295 48 25 48 C 37.690705 48 48 37.690705 48 25 C 48 12.309295 37.690705 2 25 2 z M 25 4 C 36.609824 4 46 13.390176 46 25 C 46 36.609824 36.609824 46 25 46 C 13.390176 46 4 36.609824 4 25 C 4 13.390176 13.390176 4 25 4 z M 24 13 L 24 24 L 13 24 L 13 26 L 24 26 L 24 37 L 26 37 L 26 26 L 37 26 L 37 24 L 26 24 L 26 13 L 24 13 z"/></svg></a>{% endif %}
          </div>
        </div>
        {% if block.settings.description != blank %}
        <div class="description-porvc">
          <p>{{ block.settings.description }}</p>
        </div>
        {% endif %}
      </div>
    </div>
  {% endfor %}
  </div>
  <div class="swiper-pagination"></div>
</div>
{% if section.settings.borda-inferior %}
  {% render 'borda-inferior', cor: section.settings.color-borda-inferior %}
{% endif %}
{% schema %}
  {
    "name": "Holy Por Você",
    "class": "green-section",
    "settings": [
      {
        "type": "text",
        "id": "section_title",
        "label": "Título da seção (deixe em branco para usar o padrão)",
        "info": "O título padrão é: O que a Holysoup<br />faz por você:"
      },
      {
        "type": "color",
        "id": "title_color",
        "label": "Cor do título",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "highlight_color",
        "label": "Cor do destaque",
        "default": "#00b45a"
      },
      {
        "type": "checkbox",
        "id": "borda-superior",
        "default": true,
        "label": "Ativar divisória superior"
      },
      {
        "type": "color",
        "id": "color-borda-superior",
        "default": "#fff",
        "label": "Cor da divisória superior"
      },
      {
        "type": "checkbox",
        "id": "borda-inferior",
        "default": false,
        "label": "Ativar divisória inferior"
      },
      {
        "type": "color",
        "id": "color-borda-inferior",
        "default": "#fff",
        "label": "Cor da divisória inferior"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Cor do fundo",
        "default": "#F6F6F6"
      },
      {
        "type": "color",
        "id": "card_background_color",
        "label": "Cor do fundo dos cards",
        "default": "#FFFFFF"
      }
    ],
    "blocks": [{
      "type": "feature",
      "name": "Destaque",
      "settings": [
        {
          "type": "image_picker",
          "id": "icone",
          "label": "Icone"
        },
        {
          "type": "html",
          "id": "title",
          "label": "Título"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrição"
        }
      ]
    }],
    "presets": [
      {"name": "Holy Por Você"}
    ]
  }
{% endschema %}