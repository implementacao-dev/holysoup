            class="countdown-block countdown-{{ block.id }} hide--{{ hide_countdown_fc }} shape-{{ countdown_style }}"
            data-countdown
            data-countdown-value="{{ countdown }}"
            style="--font-size-countdown-number-style: {{ font_size_countdown_number | append: 'px' }};--font-size-countdown-text-style: {{ font_size_countdown_text | append: 'px' }};--color-countdown-style: {{ color_countdown }};--color-countdown-mb-style: {{ color_countdown_mb }};--countdown-margin-bottom-style: {{ countdown_margin_bottom | append: 'px' }}"
          ></div>
        {%- endif -%}
        {%- if btn_text_2 != blank -%}
          <div class="banner-action">
            {%- if btn_text != blank -%}
              <a
                {% if link == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ link }}"
                {% endif %}
                class="banner-button button{% if enable_button_custom_border %} banner-button--custom-border{% endif %}"
                style="--button_color: {{ button_color }};--button_bg: {% if button_background_gradient != blank %}{{ button_background_gradient }}{% else %}{{ button_background}}{% endif %};--button_border: {{ button_border }};--button_width: {{ button_1_width | append: 'px' }};--button_color_hover: {{ button_color_hover }};--button_bg_hover: {% if button_background_gradient_hover != blank %}{{ button_background_gradient_hover }}{% else %}{{ button_background_hover}}{% endif %};--button_border_hover: {{ button_border_hover}}"
              >
                {%- if btn_icon != blank -%}
                  {{ btn_icon }}
                {%- endif -%}
                <span>{{ btn_text | escape }}</span>
              </a>
            {%- endif -%}
            <a
              {% if link_2 == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ link_2 }}"
              {% endif %}
              class="banner-button button banner-button-2{% if enable_button_custom_border %} banner-button--custom-border{% endif %}"
              style="--button_color: {{ button_color_2 }};--button_bg: {% if button_background_2_gradient != blank %}{{ button_background_2_gradient }}{% else %}{{ button_background_2}}{% endif %};--button_border: {{ button_border_2 }};--button_width: {{  button_1_width | append: 'px' }};--button_color_hover: {{ button_color_hover_2 }};--button_bg_hover: {% if button_background_gradient_hover_2 != blank %}{{ button_background_gradient_hover_2 }}{% else %}{{ button_background_hover_2}}{% endif %};--button_border_hover: {{ button_border_hover_2}}"
            >
              {%- if btn_icon_2 != blank -%}
                {{ btn_icon_2 }}
              {%- endif -%}
              <span>{{ btn_text_2 | escape }}</span>
            </a>
          </div>
        {%- else -%}
          {%- if btn_text != blank -%}
            <a
              {% if link == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ link }}"
              {% endif %}
              class="banner-button button{% if enable_button_custom_border %} banner-button--custom-border{% endif %}"
              style="--button_color: {{ button_color }};--button_bg: {% if button_background_gradient != blank %}{{ button_background_gradient }}{% else %}{{ button_background}}{% endif %};--button_border: {{ button_border }};--button_width: {{ button_1_width | append: 'px' }};--button_color_hover: {{ button_color_hover }};--button_bg_hover: {% if button_background_gradient_hover != blank %}{{ button_background_gradient_hover }}{% else %}{{ button_background_hover}}{% endif %};--button_border_hover: {{ button_border_hover}}"
            >
              {%- if btn_icon != blank -%}
                {{ btn_icon }}
              {%- endif -%}
              <span>{{ btn_text | escape }}</span>
            </a>
          {%- endif -%}
        {%- endif -%}
      </div>
      <div class="display-content">
        {% for block in section.blocks %}
          {% case block.type %}
            {%- when 'title' -%}
              <div class="title">
                {{ product.title }}
              </div>
            {%- when 'variant_picker' -%}
              <div
                class="productView-moreItem"
              >
                {% render 'product-variant-sonhos',
                  block: block,
                  product: product,
                  variantCount: variant_count,
                  current_variant: product.selected_or_first_available_variant,
                  picker_type: block.settings.picker_type,
                  show_variant_image_group: false
                %}
              </div>
          {% endcase %}
        {% endfor %}
        <div class="product-content">
            {% for block in section.blocks %}
              {% case block.type %}
                {%- when 'image' -%}
                  {{
                    block.settings.image
                    | image_url: width: 300
                    | image_tag
                  }}
              {% endcase %}
            {% endfor %}
          <div>
            {% for block in section.blocks %}
              {% case block.type %}
                {%- when 'price' -%}
                <div class="productView-price no-js-hidden clearfix" id="product-price-display-{{ product.id }}">
                  {%- render 'price-sonhos',
                      product: product,
                      use_variant: true,
                      price_class: 'price--medium',
                      cordestaque: product.metafields.custom.cor_de_destaque.value,
                      installment_number: block.settings.installment_number
                  -%}
                </div>
                {%- when 'buy_buttons' -%}
                  <div
                    class="productView-moreItem"
                  >
                    {% render 'product-button-sonhos',
                      block: block,
                      product: product,
                      current_variant: product.selected_or_first_available_variant,
                      section: section
                    %}
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
</div>
