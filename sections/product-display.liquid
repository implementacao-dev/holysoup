{% style %}
  .product-display {
    position: relative;
  }

  .product-display .content-box {
    width: 100%;
    display: flex;
    justify-content: center;
    gap: 100px;
    left: 0;
  }

  .product-display .content-box .banner-heading {
    color: #B4D6FF;
    font-size: 25px;
    text-align: start;
    font-family: Montserrat, sans-serif;
    margin: 0;
  }

  .product-display .content-box .banner-text {
    color: #fff;
    font-size: 17px;
    text-align: start;
    margin: 0;
  }

  .product-display .content-box > div {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: center;
  }
  
  .product-display .product-content {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
  }
  
  .product-display .content-box .price {
    align-items: start;
    font-size: 20px;
    font-weight: 600;
    color: #fff;
    padding: 16px 0;
  }
  
  .product-display .content-box .price .price-item {
    white-space: nowrap;
    color: #fff;
  }
  
  .product-display .content-box .price-installment {
    font-size: 14px;
    font-weight: 400;
    color: #B4D6FF;    
  }
  
  .product-display .content-box .title {
    font-size: 20px;
    font-weight: 600;
    color: #fff;
    padding: 16px 0;
  }
  
  .product-display .product-content img {
    width: 200px;
    height: auto;
  }

  .product-display .product-form__label .text {
    opacity: 0.2;
    border-radius: 12px;
    border: none;
    color: #000;
    background-color: #D1D1D1;
    height: auto;
    padding: 10px;
    text-align: left;
    width: 110px;
  }
  
  .product-display .product-form__label .text {
    color: #000;
    font-size: 14px;
  }
  
  .product-display .product-form__label .text .box {
    color: #000;
    font-size: 16px;
  }

  .product-display .product-form__radio:checked+.product-form__label .text {
    background-color: #FFFFFF;
    opacity: 1;
    color: #1D84EB;
    font-size: 14px;
  }
  
  .product-display .product-form__radio:checked+.product-form__label .text .box {
    color: #F5C1E1;
    font-size: 16px;
  }

  .product-display .productView-action .button {
    border-radius: 8px;
   }

  .product-display .productView-action .button {
    border-radius: 8px;
    background: #F5C1E1;
    color: white;
    box-shadow: 0px 12px 6px #00000029;
    padding: 20px 46px;
    height: auto;
    font-size: 18px;		
  }
  
  .product-display .shopify-payment-button__button--unbranded {
    border-radius: 8px;
    background: #F5C1E1;
    color: white;
    box-shadow: 0px 12px 6px #00000029;
    padding: 20px 46px;
    height: auto;
    font-size: 0 !important;		
  }

  .product-display .shopify-payment-button__button--unbranded::before {
    content: 'Comprar';
    position: absolute;    
    visibility: visible;
    top: 0;
    left: 0;
    bottom: 0;
    font-size: 18px;
    display: contents;
  }
  
  .product-display .img-box-mobile .image {
      display: none;
  }
  
  .product-display .img-box-mobile .image+.image {
      display: block;
  }

  @media (max-width: 767px) {
    .product-display .content-box {
      flex-direction: column;
      gap: 16px;
    }
  }
  
  @media (max-width: 400px) {
    .product-display .shopify-payment-button__button--unbranded {
      padding: 20px 30px;
    }
  }
  
  @media (min-width: 767px) {
    .product-display .display-info {
      width: 325px;
    }
    
    .product-display .display-content {
      width: 390px;
    }
    
    .product-display .img-box-mobile .image {
        display: block;
    }
    
    .product-display .img-box-mobile .image+.image {
        display: none;
    }

  }

  @media (min-width:767px) and (max-width:1024px) {
    .product-display .img-box-mobile .image {
        padding-top: {% unless image.presentation.focal_point == '50.0% 50.0%' %}{{ 1 | divided_by: image.aspect_ratio | times: 110 | append: '%' }}{% else %}{{ 1 | divided_by: image.aspect_ratio | times: 100 | plus: 40 | append: '%' }}{% endunless %}!important
    }
  }
{% endstyle %}

<div class="product-display">
  <div class="img-box img-box-mobile">
    {%- if image != blank -%}
      <a
        class="image image-adapt adaptive_height"
        {% if link == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ link }}"
        {% endif %}
        style="padding-top: {% unless image.presentation.focal_point == '50.0% 50.0%' %}{{ 1 | divided_by: image.aspect_ratio | times: 110 | append: '%' }}{% else %}{{ 1 | divided_by: image.aspect_ratio | times: 100 | append: '%' }}{% endunless %}"
        title="{{ preview_img.alt | default: shop.name | escape }}"
      >
        {%- assign height_dsk = image.width | divided_by: image.aspect_ratio | round -%}
        {{
          image
          | image_url: width: 3840
          | image_tag:
            loading: 'lazy',
            class: lazy,
            height: height_dsk,
            sizes: '100vw',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
        }}
        {%- if settings.enable_lazyload -%}<span class="data-lazy-loading"></span>{%- endif -%}
      </a>
    {%- else -%}
      <a
        class="image"
        title="{{ shop.name }}"
        {% if link == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ link }}"
        {% endif %}
      >
        <div class="not_img" style="--height_not_img: 720px">1880 x 720px</div>
      </a>
    {%- endif -%}
    {%- if mobile_image != blank -%}
      <a
        class="image image-mobile image-adapt adaptive_height"
        {% if link == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ link }}"
        {% endif %}
        {% if link == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ link }}"
        {% endif %}
        style="padding-top: {% unless mobile_image.presentation.focal_point == '50.0% 50.0%' %}{{ 1 | divided_by: mobile_image.aspect_ratio | times: 120 | append: '%' }}{% else %}{{ 1 | divided_by: mobile_image.aspect_ratio | times: 100 | plus: 30 | append: '%' }}{% endunless %}"
        title="{{ mobile_image.alt | default: shop.name | escape }}"
      >
        {%- assign height_mb = mobile_image.width | divided_by: mobile_image.aspect_ratio | round -%}
        {{
          mobile_image
          | image_url: width: 750
          | image_tag: loading: 'lazy', class: lazy, height: height_mb, sizes: '100vw', widths: '375, 550, 750'
        }}
        {%- if settings.enable_lazyload -%}<span class="data-lazy-loading"></span>{%- endif -%}
      </a>
    {%- else -%}
      {%- if image != blank -%}
        <a
          class="image image-mobile image-adapt adaptive_height a"
          {% if link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ link }}"
          {% endif %}
          style="padding-top: {% unless image.presentation.focal_point == '50.0% 50.0%' %}{{ 1 | divided_by: image.aspect_ratio | times: 200 | append: '%' }}{% else %}{{ 1 | divided_by: image.aspect_ratio | times: 100 | append: '%' }}{% endunless %}"
          title="{{ image.alt | default: shop.name | escape }}"
        >
          {%- assign height_mb = image.width | divided_by: image.aspect_ratio | round -%}
          {{
            image
            | image_url: width: 750
            | image_tag: loading: 'lazy', class: lazy, height: height_mb, sizes: '100vw', widths: '375, 550, 750'
          }}
          {%- if settings.enable_lazyload -%}<span class="data-lazy-loading"></span>{%- endif -%}
        </a>
      {%- else -%}
        <a
          class="image image-mobile"
          title="{{ shop.name }}"
          {% if link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ link }}"
          {% endif %}
        >
          {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
        </a>
      {%- endif -%}
    {%- endif -%}
  </div>
  {%- if heading != blank or text != blank or btn_text != blank or btn_text_2 != blank -%}
    <div
      class="content-box content-box--absolute content-box--{{ position }} text-{{ align }} align-items--{{align_items}}{% if section.settings.position == 'custom' %} custom_position{% elsif section.settings.position == 'half' %} content-box--absolute-half{% endif %}"
      style="--content_width:{{ content_width | append: 'px' }};{% if section.settings.position == 'custom' %}--horizontal_position: {{ section.settings.custom_horizontal }}%;--vertical_position: {{ section.settings.custom_vertical }}%;--minus_horizontal_position: -{{ section.settings.custom_horizontal }}%;--minus_vertical_position: -{{ section.settings.custom_vertical }}%{% endif %}"
    >
      <div class="display-info">
        {%- if sub_title != blank and sub_title_position == 'sub_title_above' -%}
          <p
            class="banner-sub-title{% if section.settings.border_sub_title %} banner-sub-title--border{% endif %}"
            style="--font_size_sub_title: {{ font_size_sub_title | append: 'px' }};--font_size_sub_title_mb:{{ font_size_sub_title_mb | append: 'px' }};--color_sub_title: {{ color_sub_title }};--color_sub_title_mb: {{ color_sub_title_mb }};--font_weight_sub_title: {{ font_weight_sub_title }};--letter_spacing_sub_title:{% if section.settings.letter_spacing_sub_title != blank %}{{ letter_spacing_sub_title }}{% else %}var(--body-letter-spacing){% endif %};--margin_bottom_sub_title: {{ margin_bottom_sub_title | append: 'px' }};--font-tab-type:{%- if section.settings.sub_heading_font == 'font_1' -%}var(--font-tab-type-1){%- else -%}var(--font-tab-type-2){%- endif -%}"
          >
            <span>{{ sub_title }}</span>
          </p>
        {%- endif -%}
        {%- if heading != blank -%}
          <h3
            class="banner-heading{% if enable_style_italic %} ft-i{% endif %}{% if sub_title_position == 'sub_title_below' %} banner-heading--sub_tl_below{% endif %}"
            style="--border-color-title-style: {{ border_color_title }};--border-color-title-mobile-style: {{ section.settings.border_color_title_mobile }};--heading_font_size: {{ heading_font_size | append: "px"}};--heading_font_size_mb: {{ heading_font_size_mb | append: 'px' }};--heading_color: {{ heading_color }}; --heading_color_mb: {{ heading_color_mb }};--heading_font_weight: {{ heading_font_weight }};--letter_spacing_heading: {% if section.settings.letter_spacing_heading != blank %}{{ letter_spacing_heading }}{% else %}var(--heading-letter-spacing){% endif %};--heading_line_height:{% if heading_font_size > headingLineHeight %}{{ heading_font_size | plus: 8 | append: 'px' }}{% else %}{{headingLineHeight | append: 'px'}}{% endif %};--heading_line_height_mb:{% if heading_font_size_mb > headingLineHeight %}{{ heading_font_size_mb | plus: 8 | append: 'px' }}{% else %}{{headingLineHeight | append: 'px'}}{% endif %};--margin_bottom_heading:{{margin_bottom_heading | append: 'px'}}"
          >
            {{ heading }}
          </h3>
        {%- endif -%}
        {%- if sub_title != blank and sub_title_position == 'sub_title_below' -%}
          <p
            class="banner-sub-title{% if section.settings.border_sub_title %} banner-sub-title--border{% endif %}"
            style="--font_size_sub_title: {{ font_size_sub_title | append: 'px' }};--font_size_sub_title_mb:{{ font_size_sub_title_mb | append: 'px' }};--color_sub_title: {{ color_sub_title }};--color_sub_title_mb: {{ color_sub_title_mb }};--font_weight_sub_title: {{ font_weight_sub_title }};--letter_spacing_sub_title:{% if section.settings.letter_spacing_sub_title != blank %}{{ letter_spacing_sub_title }}{% else %}var(--body-letter-spacing){% endif %};--margin_bottom_sub_title: {{ margin_bottom_sub_title | append: 'px' }};--font-tab-type:{%- if section.settings.sub_heading_font == 'font_1' -%}var(--font-tab-type-1){%- else -%}var(--font-tab-type-2){%- endif -%}"
          >
            <span>{{ sub_title }}</span>
          </p>
        {%- endif -%}
        {%- if countdown != blank and countdown_position == 'countdown_above_desc' -%}
          <div
            class="countdown-block countdown-{{ block.id }} hide--{{ hide_countdown_fc }} shape-{{ countdown_style }}"
            data-countdown
            data-countdown-value="{{ countdown }}"
            style="--font-size-countdown-number-style: {{ font_size_countdown_number | append: 'px' }};--font-size-countdown-text-style: {{ font_size_countdown_text | append: 'px' }};--color-countdown-style: {{ color_countdown }};--color-countdown-mb-style: {{ color_countdown_mb }};--countdown-margin-bottom-style: {{ countdown_margin_bottom | append: 'px' }}"
          ></div>
        {%- endif -%}
        {%- if text != blank -%}
          <span
            class="banner-text"
            style="--des_font_size: {{ des_font_size | append: 'px'}};--des_font_size_mb: {{ des_font_size_mb | append: 'px'}};--des_color: {{ des_color }};--des_color_mb: {{ des_color_mb }};--line_height_des: {{ line_height_des | append: 'px'}};--margin_bottom_des: {{ margin_bottom_des | append: 'px'}}"
          >
            {{- text -}}
          </span>
        {%- endif -%}
        {%- if countdown != blank and countdown_position == 'countdown_below_desc' -%}
