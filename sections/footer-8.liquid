<style>
  footer::after {
    background-image: url(https://cdn.shopify.com/s/files/1/0619/0206/1748/files/patter_background.png?v=1692130859);
    background-size: cover;
    width: 100%;
    height: 100%;
    position: absolute;
    content: '';
    top: 0;
    left: 0;
    background-position: center;
    opacity: 0.2;
    z-index: 0;
  }
  
  footer {
    position: relative;
    background-color: #00b45a;
    padding: 80px 20px 80px 20px;
  }

  @media (min-width: 1200px) {
    .footer {
      padding: 80px 120px 60px 120px;
    }
  }

  .content-footer-hs {
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .row-footer{
    max-width: 1200px;
    margin: 0 auto;
  }

  a.btn.btn-footer {
    background: transparent;
    color: #fff;
    border: 2px solid #fff;
    border-radius: 23px;
    font-size: 14px;
    padding: 10px 20px;
    width: 355px;
    margin: 0 auto;
    display: block;
    max-width: 300px;
    justify-content: center;
    display: flex;
    align-items: center;
    gap: 15px;
    font-weight: 400;
  }

  a.btn.btn-footer.btn-loja-fisica {
    background-color: #00814E;
    color: #fff;
    border-color: #00814E;
  }

  a.btn.btn-footer.btn-whatsapp {
    background-color: #FFD88A;
    border-color: #FFD88A;
    color: #00814E;
  }

  a.btn.btn-footer svg {
    width: 25px;
    height: auto;
    stroke: none;
  }

  .row-footer{
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 3px 0;
  }

  .menu-principal-footer ul {
    list-style: none;
    display: flex;
    gap: 20px;
    padding: 0;
    opacity: 0;
    pointer-events: none;
  }

  .menu-principal-footer ul li a {
    font-weight: 400;
    font-size: 14px;
    color: #fff;
  }

  .menu-footer ul {
    padding: 0;
    list-style: none;
  }
  
  .menu-footer ul li a {
    font-weight: 400;
    color: #fff;
    font-size: 13px;
  }
  
  .menu-footer li {
    padding: 3px 0;
  }
  
  .logo-footer {
    width: 33.33%;
  }
  
  .logo-footer img {
    width: 160px;
    height: auto;
  }
  
  .menu-principal-footer {width: 33.33%;}
  
  .comprar-loja-fisica {
    width: 33.33%;
  }

  .menu-footer {
    width: 33.33%;
  }

  .buttons-footer {
    width: 33.33%;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .row-copyright ul.list.list-payment {
    list-style: none;
    display: flex;
    gap: 3px;
    padding: 0;
    margin: 0;
  }

  .row-footer.row-copyright {
    text-align: center;
    color: #fff;
  }

  .row-footer.row-copyright .cnpj {
    margin-bottom: 0;
  }

  .row-footer.row-copyright p:last-child {
    font-size: 7px;
    line-height: 1.5;
    margin-top: 15px;
    font-weight: 100 !important;
  }

  .row-footer.row-copyright {
    flex-direction: column;
  }
  

  @media (min-width: 1024px){
    .row-footer.row-selos img {
      height: 45px;
      width: auto;
    }

    .row-footer.row-selos {
      gap: 10px;
      margin: 25px auto;
      display: flex;
      flex-direction: row;
    }

    .whatsapp-mobile{
      display: none !important;
    }
  }

  @media (max-width: 1024px){
    .whatsapp-desktop{
      display: none !important;
    }
    .whatsapp-mobile {
      margin: 15px 0 35px;
    }
    .row-footer.row-selos img+img {
      width: 63px;
      height: 63px;
    }
    
    .row-footer.row-selos img:first-child {
      width: 70px;
      max-height: 70px;
      object-fit: contain;
    }
    
    .row-footer.row-selos {
      gap: 10px;
      margin: 25px 0;
    }
    
    .row-footer {
      flex-wrap: wrap;
    }

    .logo-footer img {
      margin: 0 auto;
    }

    .menu-principal-footer ul {
      justify-content: center;
      display: none;
    }
    
    .logo-footer {
      width: 100%;
    }
    
    .menu-principal-footer {
      width: 100%;
    }
    
    .comprar-loja-fisica {
      width: 100%;
      margin-top: 25px;
    }
    
    .menu-footer {
      width: 50%;
    }
    
    .buttons-footer {
      width: 100%;
    }

    .buttons-footer {
      order: -2;
      margin-bottom: 25px;
    }
  }
</style>

<footer>
  <div class="content-footer-hs">
    <div class="row-footer">
      <div class="logo-footer">
        {% assign logo = section.settings.logo %}
        {% if request.path contains 'holysoup' %}
          {% assign logo = section.settings.logo_holysoup %}
        {% endif %}
        {% if section.settings.logo != blank %}
            {{ logo | image_url: width: 140 | image_tag:
              loading: "lazy",
              widths: "140, 280",
              alt: shop.name,
              width: 140,
              height: 41
            }}
        {% endif %}
      </div>
      <div class="menu-principal-footer">
        <ul>
          <li><a href="/collections/sopas-e-canjas">Sopas</a></li>
