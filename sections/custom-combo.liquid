      class="content-ajax-select"
    >
      <div class="sopas-tabs">
        {% assign tab_index = 0 %}
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'tab' %}
            {% assign tab_index = tab_index | plus: 1 %}
