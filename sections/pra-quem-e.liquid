<style>
  .topicos-hs {
    display: flex;
    max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }
    .topicos-hs .item-pra-quem-e h4 {
      margin: 0;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0;
      line-height: 1.5;
      min-height: 39px;
    }

    .topicos-hs .item-pra-quem-e .image-item img {
      width: 125px;
      height: auto;
      border-radius: 30px;
      margin-bottom: 10px;
    }

    .header-pra-quem-e-hs {
      text-align: center;
      padding: 20px;
    }

    .header-pra-quem-e-hs h3 {
      margin: 0;
      color: {{ section.settings.title_color | default: '#00b45a' }};
      font-weight: 400;
      font-size: 24px;
      letter-spacing: 0;
      line-height: 1.4;
    }

    .header-pra-quem-e-hs p {
      margin: 10px 0;
      color: {{ section.settings.subtitle_color | default: '#3c3c3c' }};
    }

    @media (max-width: 1024px) {
      .item-pra-quem-e .image-item {
        width: 125px;
        margin-right: 15px;
      }

      .topicos-hs {
        flex-direction: column;
      }

      .item-pra-quem-e .content-item {
        max-width: calc(100% - 150px);
      }

      .item-pra-quem-e {
        display: flex;
        align-items: center;
      }

      .topicos-hs .item-pra-quem-e h4 {
        font-size: 14px;
        min-height: inherit;
        font-family: var(--font-heading-family);
        line-height: 1.3;
      }

      .topicos-hs .item-pra-quem-e p {
        font-size: 10px;
        line-height: 1.4;
        margin: 5px 0;
      }
    }

    @media (min-width: 1200px) {
      .item-pra-quem-e {
        text-align: center;
      }

      .item-pra-quem-e img {
        margin: 0 auto;
      }
    }

    .pra-quem-e-hs {
      background-color: {{ section.settings.background_color | default: '#ffffff' }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
</style>

<div class="pra-quem-e-hs">
  <div class="header-pra-quem-e-hs">
    <h3>{{ section.settings.title }}</h3>
    <p>{{ section.settings.subtitle }}</p>
  </div>
  <div class="topicos-hs">
    {%- for block in section.blocks -%}
      <div class="item-pra-quem-e" {{ block.shopify_attributes }}>
        <div class="image-item">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 250 }}"
              alt="{{ block.settings.title | escape }}"
              width="125"
              height="125"
              loading="lazy"
            >
          {%- else -%}
            {%- comment -%} Fallback images {%- endcomment -%}
            {%- capture fallback_img -%}
               {%- case forloop.index -%}
                 {%- when 1 -%}https://cdn.shopify.com/s/files/1/0619/0206/1748/files/descricao_pra-quem-e_1.png?v=1694996068
                 {%- when 2 -%}https://cdn.shopify.com/s/files/1/0619/0206/1748/files/descricao_pra-quem-e_2.png?v=1694996068
                 {%- when 3 -%}https://cdn.shopify.com/s/files/1/0619/0206/1748/files/descricao_pra-quem-e_3.png?v=1694996067
                 {%- when 4 -%}https://cdn.shopify.com/s/files/1/0619/0206/1748/files/descricao_pra-quem-e_4.png?v=1694996068
                 {%- else -%}https://cdn.shopify.com/s/files/1/0619/0206/1748/files/descricao_pra-quem-e_1.png?v=1694996068
               {%- endcase -%}
             {%- endcapture -%}
            <img src="{{ fallback_img | strip }}" width="125" height="125" loading="lazy">
          {%- endif -%}
        </div>
        <div class="content-item">
          <h4>{{ block.settings.title }}</h4>
          <p>{{ block.settings.text }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>
{% schema %}
{
  "name": "Pra Quem É",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Pra quem é a HolyFoods?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Saiba se a HolyFoods é para você"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor do Fundo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do Título",
      "default": "#00b45a"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Cor do Subtítulo",
      "default": "#3c3c3c"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ícone"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Para quem..."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descrição",
          "default": "Descrição do item"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pra Quem É",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "Para quem não tem tempo",
            "text": "Sua rotina é corrida e você precisa de praticidade sem abrir mão da qualidade. A HolyFoods resolve isso em minutos."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Para quem ama comer bem",
            "text": "Sabor de comida caseira, feita com ingredientes naturais de verdade. Sem culpa, sem ultraprocessados."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Para quem cuida da saúde",
            "text": "Refeições 100% naturais, ricas em nutrientes e pensadas para quem quer se alimentar melhor todos os dias."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Para quem tem dificuldade na cozinha",
            "text": "Só precisa de água. Sem receita, sem erro, sem estresse. Se você sabe ferver água, já sabe preparar sua HolyFoods."
          }
        }
      ]
    }
  ]
}
{% endschema %}
