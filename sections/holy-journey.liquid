<section class="v2-journey" id="jornada">
  <div class="container">
    <div class="v2-journey-head">
      <div class="eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <h2>{{ section.settings.headline | escape }}</h2>
    </div>
    <div class="v2-journey-steps">
      {%- for block in section.blocks -%}
        <div class="v2-step" {{ block.shopify_attributes }}>
          <div class="day">{{ block.settings.day | escape }}</div>
          <div class="num">{{ block.settings.number | escape }}</div>
          <div class="illo">
            {% render 'holy-journey-icon', icon: block.settings.icon, custom_image: block.settings.icon_custom %}
          </div>
          <h4>{{ block.settings.title | escape }}</h4>
          <p>{{ block.settings.description | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
    <div style="text-align:center;margin-top:56px">
      <span style="display:inline-flex;align-items:center;gap:14px;background:var(--v2-brown);color:var(--v2-honey);padding:16px 28px;border-radius:999px;border:3px solid var(--v2-brown);font-family:var(--v2-font-stamp);font-size:14px;letter-spacing:0.1em;text-transform:uppercase">
        {{ section.settings.badge_icon }}
        {{ section.settings.badge_text | escape }}
      </span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Holy · Jornada",
  "tag": "section",
  "class": "holy-section-journey",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Cabeçalho" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "— Do apiário ao seu armário —" },
    { "type": "text", "id": "headline", "label": "Título", "default": "A jornada de um Holy." },
    { "type": "header", "content": "Badge" },
    { "type": "html", "id": "badge_icon", "label": "Ícone (HTML/SVG)" },
    { "type": "text", "id": "badge_text", "label": "Texto do badge", "default": "Rastreável até a colmeia. Pode perguntar." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Etapa",
      "settings": [
        { "type": "text", "id": "day", "label": "Dia", "default": "DIA 1-180" },
        { "type": "text", "id": "number", "label": "Número", "default": "01" },
        {
          "type": "select",
          "id": "icon",
          "label": "Ícone",
          "default": "bee",
          "options": [
            { "value": "bee", "label": "Abelha" },
            { "value": "harvest", "label": "Coleta" },
            { "value": "filter", "label": "Filtragem (gota)" },
            { "value": "bear", "label": "Urso" },
            { "value": "delivery", "label": "Entrega (caixa)" }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_custom",
          "label": "Ícone personalizado (opcional)",
          "info": "Ilustração exibida entre o número da etapa e o título do card (ex.: abelha, colmeia, gota de mel, urso ou caixa de entrega). Se você enviar uma imagem aqui, ela substitui o ícone escolhido no campo acima. Use arquivo quadrado, PNG ou SVG com fundo transparente. Dimensão recomendada: 96 × 96 px (mínimo 48 × 48 px)."
        },
        { "type": "text", "id": "title", "label": "Título", "default": "Abelhas trabalham" },
        { "type": "textarea", "id": "description", "label": "Descrição", "default": "180 dias de trabalho silencioso. 8 milhões de flores visitadas por colmeia. 🐝" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Holy · Jornada",
      "blocks": {
        "step-1": { "type": "step", "settings": { "day": "DIA 1-180", "number": "01", "icon": "bee", "title": "Abelhas trabalham", "description": "180 dias de trabalho silencioso. 8 milhões de flores visitadas por colmeia. 🐝" } },
        "step-2": { "type": "step", "settings": { "day": "DIA 181", "number": "02", "icon": "harvest", "title": "Coleta cuidadosa", "description": "Apiarista colhe na época certa, com cuidado e sem agitar as colmeias." } },
        "step-3": { "type": "step", "settings": { "day": "DIA 182", "number": "03", "icon": "filter", "title": "Filtragem suave", "description": "Filtramos a frio pra preservar enzimas e nutrientes. Nada de pasteurização." } },
        "step-4": { "type": "step", "settings": { "day": "DIA 183", "number": "04", "icon": "bear", "title": "Engarrafado no urso", "description": "Cada Holy recebe 330g do mel mais puro que a gente conseguiu fazer." } },
        "step-5": { "type": "step", "settings": { "day": "DIA 184-190", "number": "05", "icon": "delivery", "title": "Chega em casa", "description": "De 3 a 7 dias úteis pra bater na sua porta. Frete grátis acima de R$89." } }
      }
    }
  ]
}
{% endschema %}
