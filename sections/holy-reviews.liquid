<section class="v3-reviews" id="reviews">
  <div class="container">
    <div class="v3-reviews-head">
      <div class="eyebrow">{{ section.settings.eyebrow | escape }}</div>
      <h2>{{ section.settings.headline | escape }}</h2>
      <div class="stars">{{ section.settings.stars | escape }}</div>
    </div>
    <div class="v3-review-filter" id="v3-review-filter">
      <button class="v3-review-pill active" data-filter="Todas">{{ section.settings.filter_all | escape }}</button>
      {%- for block in section.blocks -%}
        {% if block.type == 'filter' %}
          <button class="v3-review-pill" data-filter="{{ block.settings.label | escape }}">{{ block.settings.label | escape }}</button>
        {% endif %}
      {%- endfor -%}
    </div>
    <div class="v3-review-grid" id="v3-review-grid">
      {%- for block in section.blocks -%}
        {% if block.type == 'review' %}
          <div class="v3-review-card" data-tag="{{ block.settings.tag | escape }}" {{ block.shopify_attributes }}>
            <span class="verified">{{ section.settings.verified_badge | escape }}</span>
            <div class="stars">{{ block.settings.stars | escape }}</div>
            <p class="body">{{ block.settings.body | escape }}</p>
            <div class="who">
              <div class="avatar">
                {% render 'holy-review-avatar', image: block.settings.avatar_image, letter: block.settings.avatar %}
              </div>
              <div>
                <div class="name">{{ block.settings.name | escape }}</div>
                <div class="city">{{ block.settings.city | escape }}</div>
              </div>
            </div>
          </div>
        {% endif %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Holy · Reviews",
  "tag": "section",
  "class": "holy-section-reviews",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Cabeçalho" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "4.9/5 · +2.000 AVALIAÇÕES" },
    { "type": "text", "id": "headline", "label": "Título", "default": "O que dizem as famílias" },
    { "type": "text", "id": "stars", "label": "Estrelas", "default": "★ ★ ★ ★ ★" },
    { "type": "text", "id": "filter_all", "label": "Label Todas", "default": "Todas" },
    { "type": "text", "id": "verified_badge", "label": "Badge verificado", "default": "✓ Verificado" }
  ],
  "blocks": [
    {
      "type": "filter",
      "name": "Filtro",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Sabor" }
      ]
    },
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "tag", "label": "Tag (filtro)", "default": "Sabor" },
        { "type": "text", "id": "stars", "label": "Estrelas", "default": "★ ★ ★ ★ ★" },
        { "type": "textarea", "id": "body", "label": "Depoimento", "default": "Gente, não tem comparação com mel de supermercado..." },
        {
          "type": "image_picker",
          "id": "avatar_image",
          "label": "Foto do avatar (opcional)",
          "info": "Foto circular do cliente. Arquivo quadrado. Recomendado: 88 × 88 px (exibido em 44 × 44 px). Se vazio, usa a letra abaixo."
        },
        { "type": "text", "id": "avatar", "label": "Avatar (letra — padrão)", "default": "A" },
        { "type": "text", "id": "name", "label": "Nome", "default": "Ana Paula" },
        { "type": "text", "id": "city", "label": "Cidade", "default": "São Paulo, SP" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Holy · Reviews",
      "blocks": {
        "filter-1": { "type": "filter", "settings": { "label": "Sabor" } },
        "filter-2": { "type": "filter", "settings": { "label": "Cristalização" } },
        "filter-3": { "type": "filter", "settings": { "label": "Família" } },
        "filter-4": { "type": "filter", "settings": { "label": "Treino" } },
        "review-1": { "type": "review", "settings": { "tag": "Sabor", "stars": "★ ★ ★ ★ ★", "body": "Gente, não tem comparação com mel de supermercado. O sabor é completamente diferente, parece outro produto. Nunca mais volto atrás.", "avatar": "A", "name": "Ana Paula", "city": "São Paulo, SP" } },
        "review-2": { "type": "review", "settings": { "tag": "Cristalização", "stars": "★ ★ ★ ★ ★", "body": "O meu cristalizou depois de uns meses e eu amei! Finalmente um mel de verdade. Derrete em banho-maria e fica perfeito de novo.", "avatar": "M", "name": "Mariana", "city": "Belo Horizonte, MG" } },
        "review-3": { "type": "review", "settings": { "tag": "Família", "stars": "★ ★ ★ ★ ★", "body": "Meus filhos adoram no café da manhã com iogurte. Fico tranquila sabendo que é puro e sem conservantes. Virou item obrigatório em casa.", "avatar": "J", "name": "Juliana", "city": "Rio de Janeiro, RJ" } },
        "review-4": { "type": "review", "settings": { "tag": "Sabor", "stars": "★ ★ ★ ★ ★", "body": "Uso no chá todas as manhãs. Aroma incrível, o sabor da flor de laranjeira faz toda diferença. Vale cada centavo.", "avatar": "C", "name": "Carla", "city": "Curitiba, PR" } },
        "review-5": { "type": "review", "settings": { "tag": "Treino", "stars": "★ ★ ★ ★ ★", "body": "Tomo uma colher antes do treino e funciona melhor que qualquer pré-treino caro que já experimentei. Energia limpa, sem queda depois.", "avatar": "R", "name": "Rafael", "city": "Porto Alegre, RS" } },
        "review-6": { "type": "review", "settings": { "tag": "Família", "stars": "★ ★ ★ ★ ★", "body": "Comprei o Kit Família e durou um mês só. A embalagem de urso fez sucesso com a criançada — virou disputa quem usa primeiro.", "avatar": "F", "name": "Fernanda", "city": "Salvador, BA" } }
      }
    }
  ]
}
{% endschema %}
