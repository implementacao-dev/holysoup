{%- comment -%}
  Ícone do favo/colher do hero.
  Uso: {% render 'holy-hero-dipper', image: section.settings.dipper_image %}
{%- endcomment -%}
{%- if image != blank -%}
  <img
    class="hero-dipper-img"
    src="{{ image | image_url: width: 112 }}"
    width="56"
    height="56"
    alt=""
    loading="lazy"
    aria-hidden="true"
  >
{%- else -%}
  <svg class="hero-dipper-svg" width="56" height="56" viewBox="0 0 60 50" aria-hidden="true">
    <ellipse cx="20" cy="18" rx="10" ry="8" fill="#FFF4D6" opacity="0.85" stroke="#2E1408" stroke-width="1.5" />
    <ellipse cx="38" cy="18" rx="10" ry="8" fill="#FFF4D6" opacity="0.85" stroke="#2E1408" stroke-width="1.5" />
    <ellipse cx="30" cy="30" rx="16" ry="11" fill="#F0B232" stroke="#2E1408" stroke-width="2" />
    <rect x="22" y="22" width="4" height="16" fill="#2E1408" />
    <rect x="30" y="22" width="4" height="16" fill="#2E1408" />
    <rect x="38" y="22" width="3" height="16" fill="#2E1408" />
    <circle cx="44" cy="28" r="1.5" fill="#2E1408" />
  </svg>
{%- endif -%}
