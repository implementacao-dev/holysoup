{%- comment -%}
  Urso híbrido — upload opcional ou pose SVG padrão.
  Uso: {% render 'holy-hybrid-bear', image: image, bear_symbol: bear_symbol, width: 36, class: 'nav-brand-bear' %}
{%- endcomment -%}
{%- liquid
  assign bear_symbol = bear_symbol | default: 'bear-stand-happy'
  assign w = width | default: 120
  if height != blank
    assign h = height
  else
    assign h = w | times: 230 | divided_by: 220
  endif
  assign extra_class = class | default: ''
  assign img_w = w | times: 2
-%}
{%- if image != blank -%}
  <img
    class="holy-hybrid-bear-img {{ extra_class }}"
    src="{{ image | image_url: width: img_w }}"
    width="{{ w }}"
    height="{{ h }}"
    alt=""
    loading="lazy"
    aria-hidden="true"
  >
{%- else -%}
  {% render 'holy-bear-svg', symbol: bear_symbol, width: w, height: h, class: extra_class %}
{%- endif -%}
