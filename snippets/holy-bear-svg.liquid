{%- comment -%}
  Urso SVG com <use> dimensionado corretamente (preenche o viewBox).
  Uso: {% render 'holy-bear-svg', symbol: 'bear-wave-happy', width: 180 %}
{%- endcomment -%}
{%- liquid
  assign symbol = symbol | default: 'bear-stand-happy'
  assign w = width | default: 120
  if height != blank
    assign h = height
  else
    assign h = w | times: 230 | divided_by: 220
  endif
  assign extra_class = class | default: ''
-%}
<svg
  class="bear-svg bear-blink {{ extra_class }}"
  width="{{ w }}"
  height="{{ h }}"
  viewBox="0 0 220 230"
  aria-hidden="true"
  focusable="false"
>
  <use href="#{{ symbol }}" width="220" height="230"/>
</svg>
