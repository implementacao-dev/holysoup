{%- comment -%}
  Raios solares do hero — upload opcional ou SVG animado padrão.
  Uso: {% render 'holy-sun-rays', image: section.settings.sun_rays_image %}
{%- endcomment -%}
{%- if image != blank -%}
  <img
    class="hero-sun-rays-img"
    src="{{ image | image_url: width: 800 }}"
    width="400"
    height="400"
    alt=""
    loading="eager"
    aria-hidden="true"
  >
{%- else -%}
  <svg viewBox="0 0 100 100" class="hero-sun-rays-svg" aria-hidden="true">
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(0 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(20 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(40 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(60 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(80 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(100 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(120 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(140 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(160 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(180 50 50)" opacity="0.85" />
    <polygon points="50,50 48,5 52,5" fill="rgba(240, 178, 50, 0.35)" transform="rotate(200 50 50)" opacity="0.85" />
