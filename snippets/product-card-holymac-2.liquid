        </div>
        <div class="portion-text-container">
          <span>Rende {{ block.settings.porcoes }} porções</span>
          <div class="portion-value">
            <b style="color: {{ section.settings.custom_color }}">
              /
              {{- product.selected_or_first_available_variant.price | divided_by: block.settings.porcoes | money }}
              por porção
            </b>
          </div>
        </div>
      </div>
    </div>

    <div class="cta-container {% unless product.available %}unavailable-product{% endunless %}">
      {% if false %}
        <div class="quantity-container">
          <div class="quantity">
            <quickshop-update-quantity class="previewCartItem-qty quickshop-quantity">
              <button
                @click="quantity = quantity - 1"
                x-bind:disabled="quantity == 0"
                type="button"
                name="minus"
                class="minus new-quantity btn-quantity"
              ></button>
              <input
                class="qtd-input"
                min="0"
                max="99"
                size="2"
                name="quantity"
                x-model="quantity"
                type="number"
                value="1"
                @change="handleChangeQuantity(quantity)"
              >
              <button
                @click="quantity = quantity + 1"
                type="button"
                name="plus"
                class="plus new-quantity btn-quantity"
              ></button>
            </quickshop-update-quantity>
          </div>
        </div>
      {% endif %}
      <div class="add-to-cart-container">
        {% if product.available %}
          <button
            @click="handleAdd()"
            class="btn btn-with-icon btn-primary {% if request.path == '/pages/holymac' %}font-3{% endif %}"
            style="background-color: {{ section.settings.custom_color }}"
          >
            {% render 'loading-spinner' %}
            <div x-show="!loading">+Adicionar</div>
          </button>
        {% else %}
          {% assign modal_image = product.featured_image | default: block.settings.image %}
          <button
            type="button"
            class="btn btn-with-icon btn-primary stoq-notify-me-button {% if request.path == '/pages/holymac' %}font-3{% endif %}"
            style="background-color: {{ section.settings.custom_color }} !important; color: white !important; transition: none !important;"
            data-product='{ "id": {{ product.id | json }}, "title": {{ product.title | json }}, "handle": {{ product.handle | json }}, "variants": {{ product.variants | json }}, "featured_image": {{ modal_image | image_url | json }}, "image": {{ modal_image | image_url | json }} }'
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            onclick="openRestockModal(this)"
          >
            Avise-me
          </button>
        {% endif %}
      </div>
    </div>
    {% if product.metafields.custom.cupom_value.value != blank
      and product.metafields.custom.cupom_name.value != blank
    %}
      {% liquid
        assign discountPercetage = product.metafields.custom.cupom_value.value | divided_by: 100.0
        assign discountedPrice = product.price | times: discountPercetage
        assign priceWithDiscount = product.price | minus: discountedPrice | round
      %}
      <div class="cupom">
        {{ priceWithDiscount | money }} com o cupom <u>{{ product.metafields.custom.cupom_name.value }}</u>
      </div>
    {% endif %}
  </div>
</div>
