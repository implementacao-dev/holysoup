    <div class="product-info">
      <a
        href="{{ product.url }}"
        alt="{{ product.title }}"
        class="product-title {% if request.path == '/pages/holymac' %}font-3{% endif %}"
      >
        {% if block.settings.show_product_title %}
          {{ product.title }}
        {% else %}
          {{ block.settings.title }}
        {% endif %}
      </a>
      <div class="product-description">
        {% if block.settings.show_product_description %}
          {{ product.description }}
        {% else %}
          {{ block.settings.description }}
        {% endif %}
      </div>
    </div>
    <div id="review-collections" class="product-card-review">
      <!-- Start of Judge.me code -->
      <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
        {{ product.metafields.judgeme.badge }}
      </div>
      <!-- End of Judge.me code -->
    </div>

    <div class="product-price-container">
      <div class="product-price">
        {% if product.selected_or_first_available_variant.compare_at_price
            > product.selected_or_first_available_variant.price
        -%}
          <old class="custom-font">{{ product.selected_or_first_available_variant.compare_at_price | money }}</old>
        {%- endif %}
        <new
          class="{% if request.path == '/pages/holymac' %}font-3{% endif %}"
          style="color: {{ section.settings.custom_color }} !important"
        >
          {{ product.price | money }}
        </new>
      </div>
