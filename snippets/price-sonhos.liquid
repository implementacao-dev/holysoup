<style>
  .portion-icon-container {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    background: #02B456;
    padding: 4px;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
  }

  svg.portion-icon {
    color: #fff;
    width: 28px;
    height: auto;
  }

  .portion-text-container {
    color: #231F20;
    font-size: 10px;
    display: flex;
    flex-direction: column;
    line-height: normal;
  }

  .portion-container {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .portion-value {
    font-size: 10px;
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
  }

  .portion-value b {
    color: #02B456;
  }
</style>
