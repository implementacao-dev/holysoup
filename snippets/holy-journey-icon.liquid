{%- comment -%}
  Ícones da Jornada — preset (Twemoji/gota) ou upload opcional.
  Uso: {% render 'holy-journey-icon', icon: 'bee', custom_image: block.settings.icon_custom %}
{%- endcomment -%}
{%- if custom_image != blank -%}
  <img
    class="v2-journey-icon"
    src="{{ custom_image | image_url: width: 96 }}"
    width="48"
    height="48"
    alt=""
    loading="lazy"
    aria-hidden="true"
  >
{%- else -%}
  {%- case icon -%}
    {%- when 'bee' -%}
      <img
        class="v2-journey-icon"
        src="{{ 'holy-journey-bee.svg' | asset_url }}"
        width="48"
        height="48"
        alt=""
        loading="lazy"
        aria-hidden="true"
      >
    {%- when 'harvest' -%}
      <img
        class="v2-journey-icon"
        src="{{ 'holy-journey-harvest.svg' | asset_url }}"
        width="48"
        height="48"
        alt=""
        loading="lazy"
        aria-hidden="true"
      >
    {%- when 'filter' -%}
      <img
        class="v2-journey-icon v2-journey-icon--filter"
        src="{{ 'holy-journey-filter.svg' | asset_url }}"
        width="48"
        height="48"
        alt=""
        loading="lazy"
        aria-hidden="true"
      >
    {%- when 'bear' -%}
      <img
        class="v2-journey-icon"
        src="{{ 'holy-journey-bear.svg' | asset_url }}"
        width="48"
        height="48"
        alt=""
        loading="lazy"
        aria-hidden="true"
      >
    {%- when 'delivery' -%}
      <img
        class="v2-journey-icon"
        src="{{ 'holy-journey-delivery.svg' | asset_url }}"
        width="48"
        height="48"
        alt=""
        loading="lazy"
        aria-hidden="true"
      >
  {%- endcase -%}
{%- endif -%}
