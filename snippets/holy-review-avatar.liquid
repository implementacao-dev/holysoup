{%- comment -%}
  Avatar do depoimento — foto opcional ou letra padrão.
  Uso: {% render 'holy-review-avatar', image: block.settings.avatar_image, letter: block.settings.avatar %}
{%- endcomment -%}
{%- if image != blank -%}
  <img
    class="review-avatar-img"
    src="{{ image | image_url: width: 88 }}"
    width="44"
    height="44"
    alt=""
    loading="lazy"
  >
{%- else -%}
  <span class="review-avatar-letter">{{ letter | escape }}</span>
{%- endif -%}
