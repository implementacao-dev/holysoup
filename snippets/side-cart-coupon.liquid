<div 
  class="side-cart-coupon"
  >
  <span class="side-cart-coupon-title">{{ settings.coupon_list_title }}</span>
  <div class="swiper coupon-carousel">
    <div class="swiper-wrapper">
      <div class="swiper-slide">
        <div 
          x-data="{
            copyContent() {
              const copy = async () => {
                try {
                  await navigator.clipboard.writeText(text);
                  $dispatch('show-notification', { type: 'success', description: 'Cupom copiado com sucesso' })
                } catch (err) {
                  console.error('Failed to copy: ', err);
                }
              }          
              const text = document.getElementById('coupom-name-1').innerHTML;
              copy()
            }
          }"
          class="coupon-card"
          >
          <div class="coupon-text">
            <span class="coupon-title">{{ settings.coupon_title_1 }}</span>
            <span class="coupon-description">{{ settings.coupon_description_1 }}</span>
          </div>
          <div class="coupon-name" @click="copyContent()">
            <span id="coupom-name-1">
              {{ settings.coupon_name_1 }}
            </span>
          </div>
          <button class="copy-button" @click="copyContent()">Copiar</button>
        </div>
      </div>
      <div class="swiper-slide">
        <div 
          x-data="{
            copyContent() {
              const copy = async () => {
                try {
                  await navigator.clipboard.writeText(text);
                  $dispatch('show-notification', { type: 'success', description: 'Cupom copiado com sucesso' })
                } catch (err) {
                  console.error('Failed to copy: ', err);
                }
              }          
              const text = document.getElementById('coupom-name-2').innerHTML;
              copy()
            }
          }"
          class="coupon-card"
          >
          <div class="coupon-text">
            <span class="coupon-title">{{ settings.coupon_title_2 }}</span>
            <span class="coupon-description">{{ settings.coupon_description_2 }}</span>
          </div>
          <div class="coupon-name" @click="copyContent()">
            <span id="coupom-name-2">
              {{ settings.coupon_name_2 }}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% style %}
  .side-cart-coupon {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .side-cart-coupon .side-cart-coupon-title {
    font-size: 15px;
    font-weight: 500;
    color: #3C3C3C;
  }

  .side-cart-coupon .coupon-carousel {
    width: 100%;
  }
  
  .side-cart-coupon .coupon-carousel .coupon-card {
    background: #F5F5F5;
    padding: 16px 24px;
    border-radius: 14px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  .side-cart-coupon .coupon-carousel .coupon-card .coupon-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    line-height: normal;
  }

  .side-cart-coupon .coupon-carousel .coupon-card .coupon-text .coupon-title {
    font-size: 13px;
    color: #3C3C3C;
  }

  .side-cart-coupon .coupon-carousel .coupon-card .coupon-text .coupon-description {
    font-size: 9px;
    color: #ABABAB;
  }

  .side-cart-coupon .coupon-carousel .coupon-card .coupon-name {
    font-size: 13px;
    color: #00B45A;
    padding: 12px 16px;
    border: 1px dashed #3C3C3C;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .side-cart-coupon .coupon-carousel .coupon-card .copy-button {
    font-size: 10px;
    color: #FF7A50;
    padding: 8px;
    border: 0;
    background: transparent;
  }
{% endstyle %}
