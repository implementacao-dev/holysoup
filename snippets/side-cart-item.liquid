{% liquid
  assign product_variant = item.variant
  assign quantity_id = 'quantity_' | append: key
  assign final_price = item.quantity | times: item.final_price

  assign gift = ''
  if item.final_line_price == 0
    assign gift = 'Brinde'
  endif

  assign loading = 'eager'
  assign fetchpriority = 'auto'
  if section.index == 1
    assign fetchpriority = 'high'
  elsif section.index > 2
    assign loading = 'lazy'
  endif

  assign is_bundle_item = false
  assign bundle_items_count = 0
  if item.item_components != blank and item.item_components.size > 0
    assign is_bundle_item = true
    for component in item.item_components
      assign component_qty = component.quantity | default: 1
      assign bundle_items_count = bundle_items_count | plus: component_qty
    endfor
  endif
%}
<div
  x-data="
    {
      quantity: {{ item.quantity | default: 1 }},
      isBundleOpen: false,
      handleChangeQuantity(quantity) {
        const item = { id: '{{ item.key }}', quantity: quantity }
        $store.cart.updateItem(item)
        .then(response => {
          if (quantity == 0) {
            $el.remove()
          }
        })
      },
    }
  "
  class="side-cart-item-product{% if is_bundle_item %} side-cart-item-product--bundle{% endif %}"
>
  <div class="side-cart-item-product-container">
    <div class="item-product-image">
      {% if item.image != blank %}
        {{
          item.image
          | image_url: width: item.image.width
          | image_tag: fetchpriority: fetchpriority, loading: loading
        }}
      {% endif %}
    </div>
    <div class="item-product-info">
      <div class="item-product-title">{{ item.product.title }}</div>
      <div class="item-product-price">
        {% if final_price > 0 %}
          {% if product_variant.compare_at_price > product_variant.price %}
            <p class="item-compare-at-price">{{ item.quantity | times: product_variant.compare_at_price | money }}</p>
          {% elsif product_variant.price > item.original_price %}
            <p class="item-compare-at-price">{{ item.quantity | times: product_variant.price | money }}</p>
          {% elsif item.original_price > item.price %}
            <p class="item-compare-at-price">{{ item.quantity | times: item.original_price | money }}</p>
          {% endif %}

          <p class="item-price">{{ final_price | money }}</p>
        {% else %}
          <p class="item-price">R$0,01</p>
        {% endif %}
      </div>

      {% if is_bundle_item %}
        <button
          type="button"
          class="bundle-components-toggle"
          @click="isBundleOpen = !isBundleOpen"
          :aria-expanded="isBundleOpen ? 'true' : 'false'"
          aria-controls="bundle-components-{{ key }}"
        >
          <span
            class="bundle-components-toggle__label"
            :class="{ 'bundle-components-toggle__label--hidden': isBundleOpen }"
          >
            Mostrar {{ bundle_items_count }}
            {%- if bundle_items_count == 1 %} item{% else %} itens{% endif -%}
          </span>
          <span
            class="bundle-components-toggle__label"
            :class="{ 'bundle-components-toggle__label--hidden': !isBundleOpen }"
          >Ocultar itens</span>
          <svg class="bundle-components-chevron" :class="{ 'is-open': isBundleOpen }" viewBox="0 0 10 6" aria-hidden="true">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div
          id="bundle-components-{{ key }}"
          class="bundle-components-wrapper"
          :class="{ 'bundle-components-wrapper--open': isBundleOpen }"
        >
          <div class="bundle-components-list">
            {% for component in item.item_components %}
              {% liquid
                assign component_title = component.product.title | default: component.title | default: 'Item do kit'
                assign component_image = component.image
                if component_image == blank and component.product != blank
                  assign component_image = component.product.featured_image
                endif
                assign component_qty = component.quantity | default: 1
              %}
              <div class="bundle-component-row">
                <div class="bundle-component-thumb">
                  {% if component_image != blank %}
                    {{ component_image | image_url: width: 80 | image_tag: loading: 'lazy', alt: component_title }}
                  {% endif %}
                </div>
                <div class="bundle-component-text">
                  {{ component_qty }}x {{ component_title }}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
  <div class="item-product-quantity">
    {% if final_price > 0 %}
      <div class="product-quantity-input-container">
        <div
          class="product-quantity-input"
          role="group"
        >
          <button
            type="button"
            @click="handleChangeQuantity(--quantity)"
            x-bind:disabled="quantity == 0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="#FF7A50"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" />
            </svg>
          </button>
          <input
            id="{{ quantity_id }}"
            type="tel"
            min="0"
            max="99"
            size="2"
            name="quantity"
            x-model="quantity"
            value="{{ item.quantity }}"
            @change="handleChangeQuantity(quantity)"
          >
          <button
            type="button"
            @click="handleChangeQuantity(++quantity)"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="#FF7A50"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </button>
        </div>
      </div>
    {% endif %}
    <!--
      <div class="flex flex-col justify-center">
        <button
          @click="handleChangeQuantity(0)"
          class="button-link button-black inline-flex items-center gap-1 text-body-sm font-semibold no-underline"
