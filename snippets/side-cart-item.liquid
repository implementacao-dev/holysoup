        </button>
      </div>
    -->
  </div>
</div>

{% style %}
  .side-cart-item-title {
    font-size: 15px;
    color: #3c3c3c;
    margin-bottom: 8px;
  }

  .side-cart-item-product {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .side-cart-item-product--bundle {
    align-items: flex-start;
  }

  .side-cart-item-product .side-cart-item-product-container {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px;
  }

  .side-cart-item-product .item-product-image img {
    width: 74px;
    height: auto;
  }

  .side-cart-item-product .item-product-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .side-cart-item-product .item-product-info .item-product-title {
    font-size: 13px;
    color: #3c3c3c;
  }

  .side-cart-item-product .item-product-info .item-product-price {
    display: flex;
    flex-wrap: wrap;
  }

  .side-cart-item-product .item-product-info .item-compare-at-price {
    font-size: 13px;
    font-weight: 500;
    color: #000;
    margin: 0;
    margin-right: 4px;
    text-decoration-line: line-through;
  }

  .side-cart-item-product .item-product-info .item-price {
    font-size: 13px;
    font-weight: 500;
    color: #00b45a;
    margin: 0;
  }

  .side-cart-item-product--bundle .item-product-info {
    align-items: flex-start;
  }

  .bundle-components-toggle {
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 0;
    background: transparent;
    padding: 0;
    color: #6b7280;
    font-size: 13px;
    line-height: 1.2;
    cursor: pointer;
    text-align: left;
  }

  .bundle-components-toggle:hover {
    color: #3c3c3c;
  }

  .bundle-components-toggle__label {
    display: inline-block;
    min-width: 120px;
  }

  .bundle-components-toggle__label--hidden {
    display: none;
  }

  .bundle-components-chevron {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    transition: transform 0.5s ease-in-out;
  }

  .bundle-components-chevron.is-open {
    transform: rotate(180deg);
  }

  .bundle-components-wrapper {
    width: 100%;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease-in-out;
  }

  .bundle-components-wrapper--open {
    max-height: 480px;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .bundle-components-wrapper--open::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  .bundle-components-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 10px 0 10px 4px;
    width: 100%;
  }

  .bundle-component-row {
    display: grid;
    grid-template-columns: 40px 1fr;
    align-items: start;
    gap: 8px;
  }

  .bundle-component-thumb {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bundle-component-thumb img {
    width: 40px;
    height: auto;
    max-height: 40px;
    object-fit: contain;
  }

  .bundle-component-text {
    font-size: 12px;
    margin-top: 4px;
    color: #6b7280;
    line-height: 1.3;
  }

  .item-product-quantity {
    margin-left: auto;
    display: flex;
    align-items: center;
  }

  .item-product-quantity .product-quantity-input {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    border-radius: 9999px;
    border: 1px solid #d8d8d8;
    padding: 6px 12px;
  }

  .item-product-quantity .product-quantity-input input {
    border: none;
    width: 45px;
    font-size: 22px;
    text-align: center;
  }

  .item-product-quantity .product-quantity-input button {
    border: none;
    background: transparent;
    padding: 0;
    cursor: pointer;
  }

  input::-webkit-outer-spin-button,
  input::-webkit-inner-spin-button {
    -webkit-appearance: none !important;
    margin: 0 !important;
  }

  input[type='number'] {
    -moz-appearance: textfield !important;
  }

  .item-product-quantity .product-quantity-input svg {
    width: 20px;
    height: 20px;
    stroke: #ff7a50;
    stroke-width: 3;
  }

{% endstyle %}
