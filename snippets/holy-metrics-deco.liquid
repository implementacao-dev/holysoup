{%- comment -%}
  Hexágono decorativo da seção Métricas.
  Uso: {% render 'holy-metrics-deco', image: section.settings.deco_image %}
{%- endcomment -%}
{%- if image != blank -%}
  <img
    class="v3-metrics-deco-img"
    src="{{ image | image_url: width: 320 }}"
    width="160"
    height="160"
    alt=""
    loading="lazy"
    aria-hidden="true"
  >
{%- else -%}
  <svg class="v3-metrics-deco-svg" width="160" height="160" viewBox="0 0 100 100" aria-hidden="true">
    <polygon points="50,10 80,28 80,62 50,80 20,62 20,28" fill="#F0B232" />
  </svg>
{%- endif -%}
