    <script>
      window.openRestockModal = function (button) {
        if (!button) return;

        try {
          const productDataAttr = button.getAttribute('data-product');
          const variantId = button.getAttribute('data-variant-id');
          // Check if data-product is present
          if (!productDataAttr) return;

          const productData = JSON.parse(productDataAttr);

          if (window._RestockRocket) {
            window._RestockRocket.openModal(productData, variantId);
          } else {
            // Fallback for when the recursive search fails or pure delay is needed
            setTimeout(() => {
              if (window._RestockRocket) {
                window._RestockRocket.openModal(productData, variantId);
              } else {
                const legacyBtn = document.getElementById('stoq-btn-notify-' + variantId);
                if (legacyBtn) legacyBtn.click();
              }
            }, 500);
          }
        } catch (e) {
          console.error('[Stoq] Error opening modal:', e);
        }
      };

      // Function to initialize buttons
      function initNotifyButtons() {
        const buttons = document.querySelectorAll('.stoq-notify-me-button:not([data-stoq-init])');
        buttons.forEach((button) => {
          button.setAttribute('data-stoq-init', 'true');
          button.addEventListener('click', function (e) {
            e.preventDefault();
            window.openRestockModal(this);
          });
        });
      }

      // Initialize on load and when Stoq is ready
      window.addEventListener('stoq:loaded', initNotifyButtons);
      document.addEventListener('DOMContentLoaded', initNotifyButtons);

      // MutationObserver to handle dynamic content (infinite scroll, filters)
      const stoqObserver = new MutationObserver((mutations) => {
        let shouldInit = false;
        mutations.forEach((mutation) => {
          if (mutation.addedNodes.length) {
            shouldInit = true;
          }
        });
        if (shouldInit) initNotifyButtons();
      });

      stoqObserver.observe(document.body, {
        childList: true,
        subtree: true,
      });
    </script>
